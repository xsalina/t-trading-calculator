.result-head,
.record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.record {
  border-top: 1rpx solid #E6EAF2;
  padding-top: 22rpx;
  margin-top: 22rpx;
}

.record:first-of-type {
  border-top: 0;
  padding-top: 0;
  margin-top: 0;
}

.record-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
}

.section-subtitle {
  margin-top: 22rpx;
  margin-bottom: 10rpx;
  color: #24324A;
  font-size: 26rpx;
  font-weight: 700;
}

.small-button,
.text-button {
  margin: 0;
  padding: 0 16rpx;
  width: auto;
  min-width: 0;
  max-width: 120rpx;
  box-sizing: border-box;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.small-button {
  color: #667085;
  background: #F7F8FA;
  border: 1rpx solid #E6EAF2;
}

.text-button {
  min-width: 132rpx;
  max-width: none;
  color: #E5483F;
  background: #FFF5F5;
  border: 1rpx solid #FBD6D3;
  white-space: nowrap;
}

.small-button::after,
.text-button::after {
  border: 0;
}
