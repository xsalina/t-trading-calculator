.result-head,
.record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.record {
  border-top: 1rpx solid #eef1f5;
  padding-top: 22rpx;
  margin-top: 22rpx;
}

.record:first-of-type {
  border-top: 0;
  padding-top: 0;
  margin-top: 0;
}

.record-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16202a;
}

.section-subtitle {
  margin-top: 22rpx;
  margin-bottom: 10rpx;
  color: #465567;
  font-size: 26rpx;
  font-weight: 700;
}

.small-button,
.text-button {
  margin: 0;
  padding: 0 16rpx;
  width: auto;
  min-width: 0;
  max-width: 120rpx;
  box-sizing: border-box;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.small-button {
  color: #64748b;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.text-button {
  min-width: 132rpx;
  max-width: none;
  color: #ef4444;
  background: #fff5f5;
  border: 1rpx solid #fee2e2;
  white-space: nowrap;
}

.small-button::after,
.text-button::after {
  border: 0;
}
