.calculator-result-card {
  width: 100%;
  margin-bottom: 16rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e8eef5;
  box-sizing: border-box;
}

.calculator-result-card.buy {
  border-left: 8rpx solid rgba(0, 184, 148, 0.5);
}

.calculator-result-card.sell {
  border-left: 8rpx solid rgba(214, 75, 60, 0.45);
}

.calculator-result-card.neutral {
  border-left: 8rpx solid #e2e8f0;
}

.result-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.result-card-title {
  min-width: 0;
  color: #1e293b;
  font-size: 26rpx;
  font-weight: 800;
}

.result-card-title-row {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.result-card-time {
  flex-shrink: 0;
  color: #94a3b8;
  font-size: 21rpx;
  font-weight: 500;
}

.result-card-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.result-card-meta {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.undo-button {
  margin: 0;
  padding: 0 14rpx;
  min-width: 0;
  height: 46rpx;
  line-height: 46rpx;
  border-radius: 999rpx;
  color: #ef4444;
  background: #fff5f5;
  border: 1rpx solid #fee2e2;
  font-size: 21rpx;
  font-weight: 700;
  white-space: nowrap;
  box-sizing: border-box;
}

.undo-button::after {
  border: 0;
}

.result-card-tag {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #8a97a8;
  font-size: 21rpx;
  font-weight: 600;
  white-space: nowrap;
}

.result-card-main {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.result-card-main-item {
  min-width: 0;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.calculator-result-card.buy .result-card-main-item {
  background: #f0fdf9;
}

.calculator-result-card.sell .result-card-main-item {
  background: #fff5f5;
}

.result-card-main-item text:first-child {
  display: block;
  color: #64748b;
  font-size: 20rpx;
  margin-bottom: 4rpx;
}

.result-card-main-item text:last-child {
  display: block;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.15;
  font-weight: 800;
}

.result-card-detail {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx 14rpx;
}

.result-card-detail view {
  min-width: 0;
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  color: #8a97a8;
  font-size: 21rpx;
}

.result-card-detail text:last-child {
  color: #1e293b;
  font-weight: 700;
  text-align: right;
}

.result-card-main-item text:last-child.positive,
.result-card-detail text:last-child.positive {
  color: #d64b3c;
}

.result-card-main-item text:last-child.negative,
.result-card-detail text:last-child.negative {
  color: #138a57;
}
