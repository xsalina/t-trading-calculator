.calculator-result-card {
  width: 100%;
  margin-bottom: 16rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #FFFFFF;
  border: 1rpx solid #E6EAF2;
  box-sizing: border-box;
}

.calculator-result-card.buy {
  border-left: 8rpx solid rgba(49, 87, 200, 0.45);
}

.calculator-result-card.sell {
  border-left: 8rpx solid rgba(49, 87, 200, 0.45);
}

.calculator-result-card.neutral {
  border-left: 8rpx solid rgba(49, 87, 200, 0.45);
}

.result-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.result-card-title {
  min-width: 0;
  color: #1F2937;
  font-size: 26rpx;
  font-weight: 800;
}

.result-card-title-row {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.result-card-time {
  flex-shrink: 0;
  color: #98A2B3;
  font-size: 21rpx;
  font-weight: 500;
}

.result-card-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.result-card-meta {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.undo-button {
  margin: 0;
  padding: 0 14rpx;
  min-width: 0;
  height: 46rpx;
  line-height: 46rpx;
  border-radius: 999rpx;
  color: #E5483F;
  background: #FFF5F5;
  border: 1rpx solid #FBD6D3;
  font-size: 21rpx;
  font-weight: 700;
  white-space: nowrap;
  box-sizing: border-box;
}

.undo-button::after {
  border: 0;
}

.result-card-tag {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #F7F8FA;
  color: #667085;
  font-size: 21rpx;
  font-weight: 600;
  white-space: nowrap;
}

.result-card-main {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.result-card-main-item {
  min-width: 0;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #F7F8FA;
  border: 1rpx solid #E6EAF2;
  box-sizing: border-box;
}

.calculator-result-card.buy .result-card-main-item {
  background: #F7F8FA;
}

.calculator-result-card.sell .result-card-main-item {
  background: #F7F8FA;
  border-color: #E6EAF2;
}

.result-card-main-item text:first-child {
  display: block;
  color: #98A2B3;
  font-size: 20rpx;
  margin-bottom: 4rpx;
}

.result-card-main-item text:last-child {
  display: block;
  color: #173B8F;
  font-size: 36rpx;
  line-height: 1.15;
  font-weight: 800;
}

.result-card-main-item:first-child text:last-child {
  font-size: 42rpx;
  font-weight: 800;
}

.result-card-main-item:nth-child(2) text:last-child {
  font-size: 34rpx;
  font-weight: 700;
}

.result-card-detail {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx 14rpx;
}

.result-card-detail view {
  min-width: 0;
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  color: #98A2B3;
  font-size: 20rpx;
}

.result-card-detail text:last-child {
  color: #24324A;
  font-weight: 600;
  text-align: right;
}

.result-card-main-item text:last-child.positive,
.result-card-detail text:last-child.positive {
  color: #E4572E;
  font-weight: 700;
}

.result-card-main-item text:last-child.negative,
.result-card-detail text:last-child.negative {
  color: #079455;
  font-weight: 700;
}

.result-card-main-item text:last-child.positive {
  display: inline-block;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  background: #FFF4F1;
}

.result-card-main-item text:last-child.negative {
  display: inline-block;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  background: #F0FDF4;
}
