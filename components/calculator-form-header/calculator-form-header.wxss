.calculator-form-header {
  width: 100%;
  display: block;
  flex: 0 0 100%;
  box-sizing: border-box;
  margin: 2rpx 0 8rpx;
}

.calculator-form-title-row {
  width: 100%;
  box-sizing: border-box;
  min-height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calculator-form-title {
  color: #1e293b;
  font-size: 24rpx;
  font-weight: 700;
}

.calculator-form-title-wrap {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.calculator-form-fee-row {
  width: 100%;
  min-height: 40rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  color: #8a97a8;
  font-size: 20rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.calculator-form-default-pill {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  white-space: nowrap;
}

.calculator-form-default-pill.is-default {
  background: #f1f5f9;
  color: #94a3b8;
}

.calculator-form-default-pill.can-set {
  background: #e8fff8;
  color: #00b894;
}

.calculator-form-default-help,
.calculator-form-help {
  flex-shrink: 0;
  width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
}

.calculator-form-help {
  width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  font-size: 19rpx;
}

.calculator-form-fee-row > text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.calculator-form-fee {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  white-space: nowrap;
}

.calculator-form-fee navigator,
.calculator-form-fee navigator {
  flex-shrink: 0;
  color: #008f73;
  font-size: 20rpx;
  font-weight: 700;
}

.calculator-form-remember {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #8a97a8;
  font-size: 20rpx;
  font-weight: 500;
  white-space: nowrap;
}

.calculator-form-fee switch,
.calculator-form-remember switch {
  transform: scale(0.58);
  transform-origin: center;
}

.calculator-form-header.home {
  margin: 0 0 7rpx;
}



.calculator-form-header.home .calculator-form-remember {
  gap: 4rpx;
}

.calculator-form-header.home .calculator-form-remember switch {
  transform: scale(0.58);
}
