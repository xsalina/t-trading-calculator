.calculator-pro-guide {
  width: 100%;
  margin: 20rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #F6F8FF;
  border: 1rpx solid rgba(49, 87, 200, 0.12);
  box-sizing: border-box;
}

.pro-guide-title {
  color: #1F2937;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.pro-guide-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.65;
}

.pro-guide-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.pro-guide-tag {
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: rgba(49, 87, 200, 0.055);
  color: #4264C7;
  font-size: 21rpx;
  line-height: 1.2;
}

.pro-guide-button {
  width: 100%;
  height: 70rpx;
  margin-top: 18rpx;
  border-radius: 14rpx;
 background: #6F86D8;
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 600;
}

.pro-guide-button::after {
  border: none;
}

.pro-guide-button:active {
  background:#6077CC;
}
