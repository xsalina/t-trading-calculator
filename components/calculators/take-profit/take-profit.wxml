<view class="calculator-shell {{embedded ? 'embedded' : 'standalone'}} {{result && !embedded ? 'has-fixed-action' : ''}}">
  <view class="card">
    <calculator-form-header title="止盈目标价计算器" remember-data="{{rememberData}}" show-fee="{{true}}" include-fee="{{form.includeFee}}" bindrememberchange="onRememberSwitch" bindfeechange="onFeeSwitch" />
    <view class="field"><text class="label">买入成本价</text><view class="step-field"><button class="step-button" data-key="costPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.costPrice}}" data-key="costPrice" bindinput="onInput" /><button class="step-button" data-key="costPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field"><text class="label">股数</text><view class="step-field"><button class="step-button" data-key="shares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="number" value="{{form.shares}}" data-key="shares" bindinput="onInput" /><button class="step-button" data-key="shares" data-step="100" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field"><text class="label">目标收益金额</text><input class="input" type="digit" value="{{form.targetProfit}}" data-key="targetProfit" bindinput="onInput" /></view>
  </view>
  <view class="button-row action-row">
    <button class="button primary" bindtap="calculate">计算</button>
    <button wx:if="{{!embedded}}" class="button plain" bindtap="goBack">返回</button>
  </view>
  <result-list records="{{records}}" bindclear="clearRecords" bindremove="removeRecord" />
  <view wx:if="{{result}}" class="card" style="margin-top: 20rpx;">
    <view class="section-title">计算结果</view>
    <block wx:for="{{result.rows}}" wx:key="label">
      <view class="result-row"><text>{{item.label}}</text><text class="result-value {{item.className}}">{{item.value}}</text></view>
    </block>
  </view>
  <view wx:if="{{result && embedded}}" class="result-action-row">
    <button class="button secondary result-copy-button" bindtap="copyResult">复制结果</button>
    <button class="button secondary result-share-button" open-type="share">分享给朋友</button>
    <button class="button primary pro-record-button" bindtap="openTradeRecordMiniProgram">顺手记录到做T记录助手Pro ></button>
  </view>
  <view wx:if="{{result && !embedded}}" class="result-action-bar">
    <button class="action-primary" bindtap="openTradeRecordMiniProgram">算完顺手记录这一笔</button>
    <button class="action-secondary" open-type="share">分享给朋友</button>
    <button class="action-secondary" bindtap="copyResult">复制结果</button>
  </view>

  <view wx:if="{{result}}" class="card">
    <view class="section-title">费用明细</view>
    <block wx:if="{{form.includeFee}}">
      <view class="fee-row"><text>券商佣金</text><text>¥{{result.fee.commissionText}}</text></view>
      <view class="fee-row"><text>过户费</text><text>¥{{result.fee.transferText}}</text></view>
      <view class="fee-row"><text>印花税</text><text>¥{{result.fee.stampDutyText}}</text></view>
      <view class="fee-row"><text>费用合计</text><text class="result-value">¥{{result.fee.totalText}}</text></view>
    </block>
    <view wx:else class="muted">已忽略手续费</view>
  </view>
  <view class="notice">以上结果已根据当前手续费设置估算，仅供交易记录和盈亏测算使用。本工具不构成任何投资建议。</view>
</view>
