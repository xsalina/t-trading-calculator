<view class="calculator-shell {{embedded ? 'embedded' : 'standalone'}} {{records.length && !embedded ? 'has-fixed-action' : ''}}">
  <view class="card">
    <view class="section-head compact-head">
      <view class="section-title">反T回补计算器</view>
    </view>
    <view class="compact-switch-row">
      <view class="mini-switch"><text>记住数据</text><switch color="#00b894" checked="{{rememberData}}" bindchange="onRememberSwitch" /></view>
      <view class="mini-switch"><text>计入手续费</text><switch color="#00b894" checked="{{form.includeFee}}" bindchange="onFeeSwitch" /></view>
    </view>
    <view class="fee-mini-hint">开启后自动估算交易手续费</view>
    <view wx:if="{{!embedded}}" class="fee-inline-summary">
      <text>{{feeSummary}}</text>
      <navigator url="/pages/fee-settings/fee-settings">去设置 ></navigator>
    </view>
    <view class="field"><text class="label">卖出价</text><view class="step-field"><button class="step-button" data-key="sellPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.sellPrice}}" data-key="sellPrice" bindinput="onInput" /><button class="step-button" data-key="sellPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field"><text class="label">回补价</text><view class="step-field"><button class="step-button" data-key="coverPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.coverPrice}}" data-key="coverPrice" bindinput="onInput" /><button class="step-button" data-key="coverPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field full-field"><text class="label">回补股数</text><view class="step-field"><button class="step-button" data-key="shares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="number" value="{{form.shares}}" data-key="shares" bindinput="onInput" /><button class="step-button" data-key="shares" data-step="100" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field full-field"><text class="label">回补金额（可选）</text><view class="step-field"><button class="step-button" data-key="coverAmount" data-step="-1000" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.coverAmount}}" data-key="coverAmount" bindinput="onInput" placeholder="填金额" /><button class="step-button" data-key="coverAmount" data-step="1000" data-min="0" bindtap="adjustNumber">+</button></view><view class="field-tip">填金额后，按回补价换算股数</view></view>
    <view class="field full-field">
      <text class="label">换算单位</text>
      <view class="choice-row">
        <view class="choice-item {{form.convertUnit === '100' ? 'active' : ''}}" data-unit="100" bindtap="setConvertUnit">100股</view>
        <view class="choice-item {{form.convertUnit === '200' ? 'active' : ''}}" data-unit="200" bindtap="setConvertUnit">200股</view>
        <view class="choice-item {{form.convertUnit === '1' ? 'active' : ''}}" data-unit="1" bindtap="setConvertUnit">1股</view>
      </view>
      <view class="field-tip">填写金额后，将按所选单位自动换算股数</view>
    </view>
  </view>
  <view class="button-row action-row">
    <button class="button primary" bindtap="calculate">计算</button>
    <button wx:if="{{!embedded}}" class="button plain" bindtap="goBack">返回</button>
  </view>
  <view wx:if="{{result}}" class="card" style="margin-top: 20rpx;">
    <view class="section-title">计算结果</view>
    <block wx:for="{{result.rows}}" wx:key="label">
      <view class="result-row"><text>{{item.label}}</text><text class="result-value {{item.className}}">{{item.value}}</text></view>
    </block>
  </view>
  <view wx:if="{{records.length && embedded}}" class="result-action-row">
    <button class="button primary pro-record-button" bindtap="openTradeRecordMiniProgram">算完顺手记录这一笔</button>
    <button class="button secondary result-share-button" open-type="share">分享给朋友</button>
    <button class="button secondary result-copy-button" bindtap="copyResult">复制结果</button>
  </view>
  <view wx:if="{{records.length && !embedded}}" class="result-action-bar">
    <button class="action-primary" bindtap="openTradeRecordMiniProgram">算完顺手记录这一笔</button>
    <button class="action-secondary" open-type="share">分享给朋友</button>
    <button class="action-secondary" bindtap="copyResult">复制结果</button>
  </view>

  <view wx:if="{{records.length}}" class="card">
    <view class="result-head">
      <view class="section-title">回补记录</view>
      <button class="small-button" bindtap="clearRecords">全部清除</button>
    </view>
    <block wx:for="{{records}}" wx:key="id">
      <view class="trade-record">
        <view class="trade-head">
          <view>
            <view class="record-title">{{item.title}}</view>
            <view class="hint">{{item.timeText}}</view>
          </view>
          <button class="undo-button" data-id="{{item.id}}" bindtap="undoCoverRecord">撤销本笔</button>
        </view>
        <view class="trade-line"><text>回补价</text><text>{{item.coverPriceText}}</text></view>
        <view class="trade-line"><text>回补数量</text><text>{{item.sharesText}}</text></view>
        <view class="trade-line"><text>回补金额</text><text>{{item.coverAmountText}}</text></view>
        <view class="trade-line"><text>手续费</text><text>{{item.feeText}}</text></view>
        <view class="trade-line"><text>本笔反T收益</text><text class="{{item.netProfitClass}}">{{item.netProfitText}}</text></view>
        <view class="trade-line"><text>操作后剩余待回补</text><text>{{item.remainingSharesText}}</text></view>
      </view>
    </block>
  </view>
  <view class="notice">以上结果已根据当前手续费设置估算，仅供交易记录和盈亏测算使用。本工具不构成任何投资建议。</view>
</view>
