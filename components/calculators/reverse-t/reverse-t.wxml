<view class="calculator-shell {{embedded ? 'embedded' : 'standalone'}} {{records.length && !embedded ? 'has-fixed-action' : ''}}">
  <view class="card t-home-form-card">
    <calculator-form-header title="反T回补计算器" calculator-type="reverse-t" remember-data="{{rememberData}}" show-fee="{{true}}" include-fee="{{form.includeFee}}" home="{{embedded}}" show-default="{{true}}" managed-default="{{embedded}}" is-default="{{isDefaultCalculator}}" bindrememberchange="onRememberSwitch" bindfeechange="onFeeSwitch" binddefaulttap="onDefaultCalculatorTap" />

    <view wx:if="{{!form.baseInitialized}}" class="field">
      <text class="label">卖出价</text>
      <view class="step-field">
        <button class="step-button" data-key="sellPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button>
        <input class="input" type="digit" value="{{form.sellPrice}}" data-key="sellPrice" bindinput="onInput" />
        <button class="step-button" data-key="sellPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button>
      </view>
    </view>

    <view wx:if="{{!form.baseInitialized}}" class="field">
      <text class="label">待回补股数</text>
      <view class="step-field">
        <button class="step-button" data-key="shares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button>
        <input class="input" type="number" value="{{form.shares}}" data-key="shares" bindinput="onInput" />
        <button class="step-button" data-key="shares" data-step="100" data-min="0" bindtap="adjustNumber">+</button>
      </view>
    </view>

    <calculator-result-card
      wx:if="{{form.baseInitialized && baseSellCard}}"
      title="{{baseSellCard.title}}"
      tag="{{baseSellCard.tag}}"
      theme="{{baseSellCard.theme}}"
      main-items="{{baseSellCard.mainItems}}"
      detail-items="{{baseSellCard.detailItems}}"
    />

    <view wx:if="{{form.baseInitialized}}" class="form-subtitle form-subtitle-row operation-title-row">
      <text>本次回补</text>
    </view>

    <view wx:if="{{form.baseInitialized}}" class="field">
      <text class="label">回补价</text>
      <view class="step-field">
        <button class="step-button" data-key="coverPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button>
        <input class="input" type="digit" value="{{form.coverPrice}}" data-key="coverPrice" bindinput="onInput" />
        <button class="step-button" data-key="coverPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button>
      </view>
    </view>

    <view wx:if="{{form.baseInitialized}}" class="field">
      <text class="label">回补股数</text>
      <view class="step-field">
        <button class="step-button" data-key="shares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button>
        <input class="input" type="number" value="{{form.shares}}" data-key="shares" bindinput="onInput" />
        <button class="step-button" data-key="shares" data-step="100" data-min="0" bindtap="adjustNumber">+</button>
      </view>
      <view class="amount-toggle amount-toggle-under-shares" bindtap="toggleAmountPanel">
        <text>按金额换算股数</text>
        <text>{{showAmountPanel ? ' 点击折叠' : '>'}}</text>
      </view>
    </view>

    <view wx:if="{{form.baseInitialized && showAmountPanel}}" class="field full-field">
      <text class="label">回补金额（可选）</text>
      <view class="step-field">
        <button class="step-button" data-key="coverAmount" data-step="-1000" data-min="0" bindtap="adjustNumber">-</button>
        <input class="input" type="digit" value="{{form.coverAmount}}" data-key="coverAmount" bindinput="onInput" placeholder="填金额（可选）" />
        <button class="step-button" data-key="coverAmount" data-step="1000" data-min="0" bindtap="adjustNumber">+</button>
      </view>
      <view class="field-tip">填金额后，按回补价换算股数</view>
    </view>

    <view wx:if="{{form.baseInitialized && showAmountPanel}}" class="field full-field">
      <text class="label">换算单位</text>
      <view class="choice-row">
        <view class="choice-item {{form.convertUnit === '100' ? 'active' : ''}}" data-unit="100" bindtap="setConvertUnit">100股</view>
        <view class="choice-item {{form.convertUnit === '200' ? 'active' : ''}}" data-unit="200" bindtap="setConvertUnit">200股</view>
        <view class="choice-item {{form.convertUnit === '1' ? 'active' : ''}}" data-unit="1" bindtap="setConvertUnit">1股</view>
      </view>
      <view class="field-tip">填写金额后，将按所选单位自动换算股数</view>
    </view>

    <view class="button-row">
      <button class="button primary" bindtap="calculate" disabled="{{submitting}}">{{submitting ? '保存中…' : (form.baseInitialized ? '保存回补' : '初始化卖出')}}</button>
      <button wx:if="{{form.baseInitialized}}" class="button plain" bindtap="clearRecords">全部清除</button>
    </view>
  </view>

  <calculator-result-card
    wx:if="{{preview && form.baseInitialized}}"
    title="{{preview.title}}"
    tag="{{preview.tag}}"
    theme="{{preview.theme}}"
    main-items="{{preview.mainItems}}"
    detail-items="{{preview.detailItems}}"
  />

  <view wx:if="{{result}}" id="{{calculatorKey}}-first-result-card" class="card compact-summary-card">
    <view class="summary-title">回补结果</view>
    <view class="summary-grid">
      <block wx:for="{{result.rows}}" wx:key="label">
        <view class="summary-grid-item {{item.highlight ? 'highlight' : ''}}">
          <text>{{item.label}}</text>
          <text class="result-value {{item.className}}">{{item.value}}</text>
        </view>
      </block>
    </view>
  </view>

  <view wx:if="{{records.length > 1}}" class="operation-sort-row">
    <view class="operation-sort-control">
      <text class="operation-sort-label">最新操作在前</text>
      <switch checked="{{latestFirst}}" color="#3157C8" bindchange="onOperationSortChange" />
    </view>
  </view>

  <view wx:if="{{records.length}}" class="embedded-record-list">
    <block wx:for="{{displayRecords}}" wx:key="id">
      <view id="{{calculatorKey}}-operation-{{item.id}}">
        <calculator-result-card
          title="{{item.resultTitle}}"
          tag="{{item.resultTagText}}"
          time-text="{{item.resultTimeText}}"
          theme="{{item.resultTheme}}"
          main-items="{{item.mainItems}}"
          detail-items="{{item.detailItems}}"
          removable="{{true}}"
          remove-text="撤销本笔"
          record-id="{{item.id}}"
          bindremove="undoCoverRecord"
        />
      </view>
    </block>
  </view>

  <view wx:if="{{records.length && embedded}}" class="result-action-row">
    <button class="button secondary result-share-button" open-type="share">分享给朋友</button>
    <button class="button secondary result-copy-button" bindtap="copyResult">复制结果</button>
  </view>
  <view wx:if="{{records.length && !embedded}}" class="result-action-bar">
    <button class="action-primary" bindtap="openTradeRecordMiniProgram">算完顺手记录这一笔</button>
    <button class="action-secondary" open-type="share">分享给朋友</button>
    <button class="action-secondary" bindtap="copyResult">复制结果</button>
  </view>
  <button wx:if="{{!embedded}}" class="button plain action-row" bindtap="goBack">返回</button>
  <view class="notice">以上结果已根据当前手续费设置估算，仅供交易记录和盈亏测算使用。本工具不构成任何投资建议。</view>
</view>
