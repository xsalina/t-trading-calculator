<view class="calculator-shell {{embedded ? 'embedded' : 'standalone'}}">
  <view class="card">
    <calculator-form-header title="卖出测算计算器" calculator-type="sell-estimate" remember-data="{{rememberData}}" show-fee="{{true}}" include-fee="{{form.includeFee}}" home="{{embedded}}" show-default="{{true}}" managed-default="{{embedded}}" is-default="{{isDefaultCalculator}}" bindrememberchange="onRememberSwitch" bindfeechange="onFeeSwitch" binddefaulttap="onDefaultCalculatorTap" />
    <view class="field"><text class="label">持仓成本价</text><view class="step-field"><button class="step-button" data-key="costPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.costPrice}}" data-key="costPrice" bindinput="onInput" /><button class="step-button" data-key="costPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field"><text class="label">计划卖出价</text><view class="step-field"><button class="step-button" data-key="sellPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.sellPrice}}" data-key="sellPrice" bindinput="onInput" /><button class="step-button" data-key="sellPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field"><text class="label">当前持仓股数</text><view class="step-field"><button class="step-button" data-key="totalShares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="number" value="{{form.totalShares}}" data-key="totalShares" bindinput="onInput" /><button class="step-button" data-key="totalShares" data-step="100" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field"><text class="label">计划卖出股数</text><view class="step-field"><button class="step-button" data-key="sellShares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="number" value="{{form.sellShares}}" data-key="sellShares" bindinput="onInput" /><button class="step-button" data-key="sellShares" data-step="100" data-min="0" bindtap="adjustNumber">+</button></view></view>
  </view>
  <view class="button-row action-row">
    <button class="button primary" bindtap="calculate" disabled="{{submitting}}">{{submitting ? '计算中…' : '计算'}}</button>
    <button wx:if="{{!embedded}}" class="button plain" bindtap="goBack">返回</button>
  </view>
  <view wx:if="{{records.length}}" class="embedded-record-list result-section">
    <block wx:for="{{records}}" wx:key="id">
      <view id="{{index === 0 ? calculatorKey + '-first-result-card' : calculatorKey + '-record-' + item.id}}">
        <calculator-result-card
          title="{{item.resultTitle}}"
          tag="{{item.resultTagText}}"
          theme="{{item.resultTheme}}"
          main-items="{{item.mainItems}}"
          detail-items="{{item.detailItems}}"
          removable="{{true}}"
          remove-text="删除"
          record-id="{{item.id}}"
          bindremove="removeRecord"
        />
        <view class="result-action-row record-result-action-row">
          <button class="button secondary result-share-button" data-share-kind="result" data-id="{{item.id}}" bindtap="setShareRecord" open-type="share">分享给朋友</button>
          <button class="button secondary result-copy-button" data-id="{{item.id}}" bindtap="copyResult">复制结果</button>
        </view>
        <calculator-pro-guide
          wx:if="{{index === 0}}"
          calculator-type="sell-estimate"
          source-page="{{embedded ? 'tab' : 'detail'}}"
          entry-position="action_after"
          has-result="{{records.length > 0}}"
          result-count="{{records.length}}"
          direction="SELL"
          form="{{form}}"
        />
      </view>
    </block>
  </view>
  <view class="notice">以上结果已根据当前手续费设置估算，仅供交易记录和盈亏测算使用。本工具不构成任何投资建议。</view>
</view>
