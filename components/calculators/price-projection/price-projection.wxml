<view class="calculator-shell {{embedded ? 'embedded' : 'standalone'}}">
  <view class="card">
    <calculator-form-header title="涨跌幅推演计算器" calculator-type="price-projection" remember-data="{{rememberData}}" show-default="{{true}}" managed-default="{{embedded}}" is-default="{{isDefaultCalculator}}" bindrememberchange="onRememberSwitch" binddefaulttap="onDefaultCalculatorTap" />
    <view class="field">
      <text class="label">起始价格</text>
      <view class="step-field"><button class="step-button" data-key="startPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.startPrice}}" data-key="startPrice" bindinput="onInput" /><button class="step-button" data-key="startPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button></view>
    </view>
    <view class="field">
      <text class="label">股票数量</text>
      <view class="step-field"><button class="step-button" data-key="shares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="number" value="{{form.shares}}" data-key="shares" bindinput="onInput" /><button class="step-button" data-key="shares" data-step="100" data-min="0" bindtap="adjustNumber">+</button></view>
    </view>
    <view class="field">
      <text class="label">每日涨跌幅（%）</text>
      <view class="step-field"><button class="step-button" data-key="changeRate" data-step="-0.5" bindtap="adjustNumber">-</button><input class="input" value="{{form.changeRate}}" data-key="changeRate" bindinput="onInput" placeholder="例：2 或 -2" /><button class="step-button" data-key="changeRate" data-step="0.5" bindtap="adjustNumber">+</button></view>
      <view class="hint">支持正负数，例如 2 表示每天上涨 2%，-2 表示每天下跌 2%。</view>
    </view>
  </view>

  <view class="button-row action-row">
    <button class="button primary" bindtap="calculate" disabled="{{submitting}}">{{submitting ? '生成中…' : '计算50天'}}</button>
    <button wx:if="{{!embedded}}" class="button plain" bindtap="goBack">返回</button>
  </view>

  <view wx:if="{{records.length}}" class="embedded-record-list result-section">
    <block wx:for="{{records}}" wx:key="id">
      <view id="{{index === 0 ? calculatorKey + '-first-result-card' : calculatorKey + '-record-' + item.id}}">
        <calculator-result-card
          title="{{item.resultTitle}}"
          tag="{{item.resultTagText}}"
          theme="{{item.resultTheme}}"
          main-items="{{item.mainItems}}"
          detail-items="{{item.detailItems}}"
          removable="{{true}}"
          remove-text="删除"
          record-id="{{item.id}}"
          bindremove="removeRecord"
        />
        <view class="result-action-row record-result-action-row">
          <button class="button secondary result-share-button" data-id="{{item.id}}" bindtap="setShareRecord" open-type="share">分享给朋友</button>
          <button class="button secondary result-copy-button" data-id="{{item.id}}" bindtap="copyResult">复制结果</button>
        </view>
        <calculator-pro-guide
          wx:if="{{index === 0}}"
          calculator-type="price-projection"
          source-page="{{embedded ? 'tab' : 'detail'}}"
          entry-position="action_after"
          has-result="{{records.length > 0}}"
          result-count="{{records.length}}"
          form="{{form}}"
        />
        <view class="projection-detail-card">
          <view class="projection-detail-toggle" data-id="{{item.id}}" bindtap="toggleProjectionDetail">
            <text>近50天明细</text>
            <text>{{item.showDetails ? ' 点击折叠' : '点击展开 >'}}</text>
          </view>
          <view wx:if="{{item.showDetails}}" class="projection-table">
            <view class="projection-head">
              <text>天数/日期</text>
              <text>价格</text>
              <text>市值</text>
              <text>盈亏</text>
              <text>累计涨跌</text>
            </view>
            <block wx:for="{{item.projectionRows}}" wx:for-item="row" wx:key="day">
              <view class="projection-line">
                <text>{{row.dateText}}</text>
                <text>{{row.price}}</text>
                <text>{{row.marketValue}}</text>
                <text class="{{row.className}}">{{row.profit}}</text>
                <text class="{{row.className}}">{{row.changeRate}}</text>
              </view>
            </block>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="notice">本页按固定涨跌幅做复利推演，不代表真实行情。本工具仅用于测算，不构成任何投资建议。</view>
</view>
