@import "../calculator-common.wxss";

calculator-result-card .result-card-main-item:first-child {
  background: #F7F8FA;
  border-color: #E6EAF2;
}

calculator-result-card .result-card-main-item:first-child text:last-child {
  color: #173B8F;
  background: transparent;
  padding: 0;
  font-size: 34rpx;
  font-weight: 700;
}

calculator-result-card .result-card-main-item:nth-child(2) text:last-child {
  font-size: 42rpx;
  font-weight: 800;
}

.projection-detail-card {
  width: 100%;
  margin: -8rpx 0 18rpx;
  padding: 0 16rpx 14rpx;
  border-radius: 0 0 16rpx 16rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E6EAF2;
  box-sizing: border-box;
}

.projection-detail-toggle {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #3157C8;
  font-size: 24rpx;
  font-weight: 700;
}

.projection-table {
  overflow: hidden;
  border-radius: 12rpx;
  border: 1rpx solid #E6EAF2;
}

.projection-head,
.projection-line {
  display: grid;
  grid-template-columns: 1.05fr 1.15fr 1.4fr 1.35fr 1.25fr;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 10rpx;
  box-sizing: border-box;
}

.projection-head {
  background: #F7F8FA;
  color: #667085;
  font-size: 20rpx;
  font-weight: 700;
}

.projection-line {
  min-height: 58rpx;
  color: #24324A;
  font-size: 20rpx;
  border-top: 1rpx solid #E6EAF2;
}

.projection-line text,
.projection-head text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
