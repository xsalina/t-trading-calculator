.calculator-shell.standalone {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.calculator-shell.embedded {
  padding: 0;
  box-sizing: border-box;
}

.calculator-shell.embedded .card {
  margin-bottom: 10rpx;
  padding: 14rpx;
}

.calculator-shell.embedded .section-head {
  margin-bottom: 8rpx;
}

.calculator-shell.embedded .section-title {
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.calculator-shell.embedded .field {
  margin-bottom: 22rpx;
}

.calculator-shell.embedded .label {
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.calculator-shell.embedded .input {
  height: 64rpx;
  font-size: 28rpx;
}

.calculator-shell.embedded .step-field {
  grid-template-columns: 54rpx minmax(0, 1fr) 54rpx;
  gap: 8rpx;
}

.calculator-shell.embedded .step-button {
  width: 54rpx;
  min-width: 54rpx;
  max-width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  font-size: 30rpx;
}

.calculator-shell.embedded .segmented {
  margin-bottom: 8rpx;
  padding: 4rpx;
}

.calculator-shell.embedded .segment {
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
}

.calculator-shell.embedded .button-row {
  gap: 16rpx;
  margin-top: 20rpx;
}

.calculator-shell.embedded .button-row .button {
  height: 78rpx;
  line-height: 78rpx;
  min-height: 78rpx;
  font-size: 30rpx;
}

.calculator-shell.embedded .notice {
  display: none;
}

.calculator-shell.embedded navigator.button.secondary {
  display: none;
}

.t-home-form-card {
  align-items: stretch;
}

calculator-form-header {
  width: 100%;
  flex: 0 0 100%;
  display: block;
  box-sizing: border-box;
}

.form-subtitle {
  width: 100%;
  margin: 2rpx 0 6rpx;
  color: #1e293b;
  font-size: 26rpx;
  font-weight: 800;
}

.form-subtitle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.form-subtitle-row > text {
  flex-shrink: 0;
}

.calculator-shell.embedded .t-home-form-card .form-subtitle {
  margin: 10rpx 0;
  font-size: 26rpx;
}

.calculator-shell.embedded .t-home-form-card .form-subtitle-row {
  min-height: 42rpx;
}

.operation-title-row {
  margin-top: 1rpx;
}

.clear-action-button {
  flex: 0 0 calc(34% - 8rpx);
  width: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #98A2B3;
  background: #ffffff;
  border: 1rpx solid #E4E9F2;
  box-shadow: none;
  font-size: 28rpx;
  font-weight: 400;
  white-space: nowrap;
}

.clear-action-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.clear-action-button + .button.primary {
  flex: 0 0 calc(66% - 8rpx);
  width: auto;
}

.clear-action-button:hover,
.clear-action-button:active {
  color: #7C8799;
  background: #F8FAFC;
}

.direction-select-row {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin: 0 0 14rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #F2F4F7;
  box-sizing: border-box;
}

.direction-select-item {
  min-height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  color: #667085;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
  box-sizing: border-box;
}

.direction-select-item.active {
  background: #3157C8;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(49, 87, 200, 0.18);
}

.mini-direction-switch {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 3rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
}

.mini-direction-item {
  min-width: 72rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #667085;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.mini-direction-item.active {
  background: #3157C8;
  color: #ffffff;
}

.amount-toggle {
  width: 100%;
  min-height: 44rpx;
  margin: -1rpx 0 7rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #3157C8;
  font-size: 26rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.amount-toggle-under-shares {
  min-height: 38rpx;
  margin: 18rpx 0 0;
  padding-left: 0;
  justify-content: flex-end;
  gap: 8rpx;
  font-size: 26rpx;
}

.base-position-card {
  width: 100%;
  margin: 2rpx 0 9rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid #E6EAF2;
  border-left: 8rpx solid rgba(49, 87, 200, 0.5);
  box-sizing: border-box;
}

.base-position-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
  color: #1F2937;
  font-size: 24rpx;
  font-weight: 800;
}

.base-position-cash {
  font-size: 24rpx;
  font-weight: 800;
}

.base-position-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx 12rpx;
}

.base-position-grid view {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.base-position-grid text:first-child {
  color: #98A2B3;
  font-size: 20rpx;
}

.base-position-grid text:last-child {
  color: #173B8F;
  font-size: 23rpx;
  font-weight: 700;
}

.base-position-grid text:last-child.positive {
  color: #E4572E;
}

.base-position-grid text:last-child.negative {
  color: #079455;
}

.base-detail-toggle {
  width: 100%;
  min-height: 42rpx;
  margin-top: 10rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #E6EAF2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #3157C8;
  font-size: 21rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.base-detail-grid {
  margin-top: 8rpx;
}

.embedded-record-list {
  width: 100%;
  margin-bottom: 12rpx;
}

.result-section {
  border-radius: 16rpx;
}

.operation-sort-row {
  width: 100%;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 16rpx 4rpx 12rpx;
  box-sizing: border-box;
}

.operation-sort-control {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.operation-sort-label {
  color: #8793a8;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.operation-sort-control switch {
  transform: scale(0.72);
  transform-origin: right center;
  margin-right: -10rpx;
}

.t-operation-toolbar {
  justify-content: space-between;
  padding: 18rpx 4rpx 14rpx;
}

.operation-list-title {
  color: #1F2937;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.compact-summary-card {
  padding: 16rpx;
  border-left: 8rpx solid rgba(49, 87, 200, 0.45);
}

.summary-title {
  color: #1F2937;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.summary-main {
  padding: 8rpx 0 10rpx;
  border-bottom: 1rpx solid #E6EAF2;
}

.summary-main-label {
  color: #98A2B3;
  font-size: 20rpx;
}

.summary-main-value {
  margin-top: 3rpx;
  color: #173B8F;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 800;
}

.summary-main-value.positive {
  color: #E4572E;
}

.summary-main-value.negative {
  color: #079455;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx 12rpx;
  padding-top: 10rpx;
}

.summary-grid-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
  color: #98A2B3;
  font-size: 19rpx;
}

.summary-grid-item.highlight {
  padding: 12rpx;
  border-radius: 12rpx;
  background: #F7F8FA;
  border: 1rpx solid #E6EAF2;
  box-sizing: border-box;
}

.summary-grid-item .result-value {
  color: #24324A;
  font-size: 22rpx;
  font-weight: 600;
}

.summary-grid-item.highlight .result-value {
  color: #173B8F;
  font-size: 30rpx;
  line-height: 1.15;
  font-weight: 800;
}

.summary-grid-item .result-value.positive {
  color: #E4572E;
  font-weight: 700;
}

.summary-grid-item .result-value.negative {
  color: #079455;
  font-weight: 700;
}

.result-action-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin: 4rpx 0 18rpx;
}

.record-result-action-row {
  margin: -6rpx 0 18rpx;
  padding: 0 4rpx;
}

.result-action-row .button {
  height: 68rpx;
  min-height: 68rpx;
  line-height: 68rpx;
  margin: 0;
  padding: 0 14rpx;
  border-radius: 12rpx;
  font-size: 25rpx;
  white-space: nowrap;
}

.pro-record-button {
  flex: 0 0 100%;
  min-width: 0;
  background: #F5F7FB;
  color: #3157C8;
  border: 1rpx solid rgba(49, 87, 200, 0.26);
  box-shadow: none;
}

.result-action-row .result-share-button {
  flex: 1;
  min-width: 0;
  background: #EEF3FF;
  color: #2448A8;
  border: 1rpx solid rgba(49, 87, 200, 0.25);
  box-shadow: none;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 10rpx;
  white-space: nowrap;
}

.result-action-row .result-copy-button {
  flex: 1;
  min-width: 0;
  background: #FFFFFF;
  color: #3157C8;
  border: 2rpx solid rgba(49, 87, 200, 0.32);
  box-shadow: none;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 10rpx;
  white-space: nowrap;
}

.result-action-row .result-share-button:active {
  background: #DDE7FF;
}

.result-action-row .result-copy-button:active {
  background: #F3F6FF;
}

.compact-head {
  margin-bottom: 10rpx;
}

.compact-switch-row {
  width: 100%;
  min-height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 6rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.single-switch-row {
  justify-content: flex-start;
}
