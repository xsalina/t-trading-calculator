.calculator-shell.standalone {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.calculator-shell.standalone.has-fixed-action {
  padding-bottom: calc(240rpx + env(safe-area-inset-bottom));
}

.calculator-shell.embedded {
  padding: 0;
  box-sizing: border-box;
}

.calculator-shell.embedded .card {
  margin-bottom: 10rpx;
  padding: 14rpx;
}

.calculator-shell.embedded .section-head {
  margin-bottom: 8rpx;
}

.calculator-shell.embedded .section-title {
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.calculator-shell.embedded .field {
  margin-bottom: 7rpx;
}

.calculator-shell.embedded .label {
  margin-bottom: 5rpx;
  font-size: 22rpx;
}

.calculator-shell.embedded .input {
  height: 52rpx;
  font-size: 25rpx;
}

.calculator-shell.embedded .step-field {
  grid-template-columns: 42rpx minmax(0, 1fr) 42rpx;
  gap: 5rpx;
}

.calculator-shell.embedded .step-button {
  width: 42rpx;
  min-width: 42rpx;
  max-width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  font-size: 25rpx;
}

.calculator-shell.embedded .segmented {
  margin-bottom: 8rpx;
  padding: 4rpx;
}

.calculator-shell.embedded .segment {
  height: 48rpx;
  line-height: 48rpx;
  font-size: 23rpx;
}

.calculator-shell.embedded .button-row {
  gap: 10rpx;
  margin-top: 20rpx;
}

.calculator-shell.embedded .button-row .button {
  height: 58rpx;
  line-height: 58rpx;
  min-height: 58rpx;
  font-size: 25rpx;
}

.calculator-shell.embedded .notice {
  display: none;
}

.calculator-shell.embedded navigator.button.secondary {
  display: none;
}

.t-home-form-card {
  align-items: stretch;
}

calculator-form-header {
  width: 100%;
  flex: 0 0 100%;
  display: block;
  box-sizing: border-box;
}

.form-subtitle {
  width: 100%;
  margin: 2rpx 0 6rpx;
  color: #1e293b;
  font-size: 24rpx;
  font-weight: 700;
}

.form-subtitle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.form-subtitle-row > text {
  flex-shrink: 0;
}

.calculator-shell.embedded .t-home-form-card .form-subtitle {
  margin: 0 0 5rpx;
  font-size: 23rpx;
}

.calculator-shell.embedded .t-home-form-card .form-subtitle-row {
  min-height: 42rpx;
}

.operation-title-row {
  margin-top: 1rpx;
}

.mini-direction-switch {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 3rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
}

.mini-direction-item {
  min-width: 72rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.mini-direction-item.active {
  background: #00b894;
  color: #ffffff;
}

.amount-toggle {
  width: 100%;
  min-height: 44rpx;
  margin: -1rpx 0 7rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #008f73;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.base-position-card {
  width: 100%;
  margin: 2rpx 0 9rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e8eef5;
  box-sizing: border-box;
}

.base-position-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
  color: #1e293b;
  font-size: 24rpx;
  font-weight: 800;
}

.base-position-cash {
  font-size: 24rpx;
  font-weight: 800;
}

.base-position-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx 12rpx;
}

.base-position-grid view {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.base-position-grid text:first-child {
  color: #8a97a8;
  font-size: 20rpx;
}

.base-position-grid text:last-child {
  color: #1e293b;
  font-size: 23rpx;
  font-weight: 700;
}

.base-position-grid text:last-child.positive {
  color: #d64b3c;
}

.base-position-grid text:last-child.negative {
  color: #138a57;
}

.base-detail-toggle {
  width: 100%;
  min-height: 42rpx;
  margin-top: 10rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #eef2f7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #008f73;
  font-size: 21rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.base-detail-grid {
  margin-top: 8rpx;
}

.embedded-record-list {
  width: 100%;
  margin-bottom: 12rpx;
}

.compact-summary-card {
  padding: 16rpx;
}

.summary-title {
  color: #1e293b;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.summary-main {
  padding: 8rpx 0 10rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.summary-main-label {
  color: #64748b;
  font-size: 21rpx;
}

.summary-main-value {
  margin-top: 3rpx;
  color: #1e293b;
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 800;
}

.summary-main-value.positive {
  color: #d64b3c;
}

.summary-main-value.negative {
  color: #138a57;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx 12rpx;
  padding-top: 10rpx;
}

.summary-grid-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
  color: #8a97a8;
  font-size: 20rpx;
}

.summary-grid-item.highlight {
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f0fdf9;
  box-sizing: border-box;
}

.summary-grid-item .result-value {
  color: #1e293b;
  font-size: 23rpx;
  font-weight: 700;
}

.summary-grid-item.highlight .result-value {
  color: #0f766e;
  font-size: 28rpx;
  line-height: 1.15;
  font-weight: 800;
}

.summary-grid-item .result-value.positive {
  color: #d64b3c;
}

.summary-grid-item .result-value.negative {
  color: #138a57;
}

.result-action-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin: 4rpx 0 18rpx;
}

.result-action-row .button {
  height: 68rpx;
  min-height: 68rpx;
  line-height: 68rpx;
  margin: 0;
  padding: 0 14rpx;
  border-radius: 12rpx;
  font-size: 25rpx;
  white-space: nowrap;
}

.pro-record-button {
  flex: 0 0 100%;
  min-width: 0;
  background: #e8fff8;
  color: #008f73;
  border: 1rpx solid rgba(0, 184, 148, 0.26);
  box-shadow: none;
}

.result-action-row .result-share-button {
  flex: 1;
  min-width: 0;
  background: #ffffff;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
  box-shadow: none;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 10rpx;
  white-space: nowrap;
}

.result-action-row .result-copy-button {
  flex: 1;
  min-width: 0;
  background: #ffffff;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
  box-shadow: none;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 10rpx;
  white-space: nowrap;
}

.result-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.action-primary,
.action-secondary {
  margin: 0;
  min-width: 0;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.action-primary {
  flex: 0 0 100%;
  padding: 0 20rpx;
  background: #00b894;
  color: #ffffff;
  font-size: 28rpx;
}

.action-secondary {
  flex: 1;
  width: auto;
  padding: 0 10rpx;
  background: #eafaf5;
  color: #00b894;
  font-size: 26rpx;
}

.action-primary::after,
.action-secondary::after {
  border: 0;
}

.compact-head {
  margin-bottom: 10rpx;
}

.compact-switch-row {
  width: 100%;
  min-height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 6rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.single-switch-row {
  justify-content: flex-start;
}
