<view class="calculator-shell {{embedded ? 'embedded' : 'standalone'}} {{operations.length && !embedded ? 'has-fixed-action' : ''}}">
  <view class="card t-home-form-card">
    <calculator-form-header title="做T计算器" calculator-type="t-profit" remember-data="{{rememberData}}" show-fee="{{true}}" include-fee="{{form.includeFee}}" home="{{embedded}}" show-default="{{true}}" managed-default="{{embedded}}" is-default="{{isDefaultCalculator}}" bindrememberchange="onRememberSwitch" bindfeechange="onSwitchChange" binddefaulttap="onDefaultCalculatorTap" />
    <view wx:if="{{!form.baseInitialized}}" class="field">
      <text class="label">初始持仓价格</text>
      <view class="step-field">
        <button class="step-button" data-key="initialPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">
          -
        </button>
        <input class="input" type="digit" value="{{form.initialPrice}}" data-key="initialPrice" bindinput="onInput" />
        <button class="step-button" data-key="initialPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">
          +
        </button>
      </view>
    </view>
    <view wx:if="{{!form.baseInitialized}}" class="field">
      <text class="label">初始持仓数量</text>
      <view class="step-field">
        <button class="step-button" data-key="initialShares" data-step="-100" data-min="0" bindtap="adjustNumber">
          -
        </button>
        <input class="input" type="number" value="{{form.initialShares}}" data-key="initialShares" bindinput="onInput" />
        <button class="step-button" data-key="initialShares" data-step="100" data-min="0" bindtap="adjustNumber">
          +
        </button>
      </view>
    </view>
    <calculator-result-card
      wx:if="{{form.baseInitialized && baseInfo}}"
      title="{{baseInfo.title}}"
      tag="{{baseInfo.tag}}"
      theme="{{baseInfo.theme}}"
      main-items="{{baseInfo.mainItems}}"
      detail-items="{{baseInfo.detailItems}}"
    />
    <view wx:if="{{form.baseInitialized}}" class="form-subtitle form-subtitle-row operation-title-row">
      <text>新交易方向</text>
      <view class="mini-direction-switch">
        <view class="mini-direction-item {{form.direction === 'SELL' ? 'active' : ''}}" data-direction="SELL" bindtap="setDirection">
          卖出
        </view>
        <view class="mini-direction-item {{form.direction === 'BUY' ? 'active' : ''}}" data-direction="BUY" bindtap="setDirection">
          买入
        </view>
      </view>
    </view>
    <view wx:if="{{form.baseInitialized}}" class="field">
      <text class="label">{{form.direction === 'SELL' ? '卖出' : '买入'}}价格</text>
      <view class="step-field">
        <button class="step-button" data-key="tradePrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">
          -
        </button>
        <input class="input" type="digit" value="{{form.tradePrice}}" data-key="tradePrice" bindinput="onInput" />
        <button class="step-button" data-key="tradePrice" data-step="0.01" data-min="0" bindtap="adjustNumber">
          +
        </button>
      </view>
    </view>
    <view wx:if="{{form.baseInitialized}}" class="field">
      <text class="label">{{form.direction === 'SELL' ? '卖出' : '买入'}}数量</text>
      <view class="step-field">
        <button class="step-button" data-key="tradeShares" data-step="-100" data-min="0" bindtap="adjustNumber">
          -
        </button>
        <input class="input" type="number" value="{{form.tradeShares}}" data-key="tradeShares" bindinput="onInput" />
        <button class="step-button" data-key="tradeShares" data-step="100" data-min="0" bindtap="adjustNumber">
          +
        </button>
      </view>
    </view>
    <view wx:if="{{form.baseInitialized && form.direction === 'BUY'}}" class="amount-toggle" bindtap="toggleEmbeddedAmountPanel">
      <text>按金额换算股数</text>
      <text>{{showEmbeddedAmountPanel ? '收起' : '>'}}</text>
    </view>
    <view wx:if="{{form.baseInitialized && form.direction === 'BUY' && showEmbeddedAmountPanel}}" class="field full-field">
      <text class="label">买入金额（可选）</text>
      <view class="step-field">
        <button class="step-button" data-key="tradeAmount" data-step="-1000" data-min="0" bindtap="adjustNumber">
          -
        </button>
        <input class="input" type="digit" value="{{form.tradeAmount}}" data-key="tradeAmount" bindinput="onInput" placeholder="填金额（可选）" />
        <button class="step-button" data-key="tradeAmount" data-step="1000" data-min="0" bindtap="adjustNumber">
          +
        </button>
      </view>
      <view class="field-tip">填写金额后，按买入价格自动换算数量</view>
    </view>
    <view wx:if="{{form.baseInitialized && form.direction === 'BUY' && showEmbeddedAmountPanel}}" class="field full-field">
      <text class="label">换算单位</text>
      <view class="choice-row">
        <view class="choice-item {{form.convertUnit === '100' ? 'active' : ''}}" data-unit="100" bindtap="setConvertUnit">
          100股
        </view>
        <view class="choice-item {{form.convertUnit === '200' ? 'active' : ''}}" data-unit="200" bindtap="setConvertUnit">
          200股
        </view>
        <view class="choice-item {{form.convertUnit === '1' ? 'active' : ''}}" data-unit="1" bindtap="setConvertUnit">
          1股
        </view>
      </view>
      <view class="field-tip">填写金额后，将按所选单位自动换算股数</view>
    </view>
    <view class="button-row">
      <button class="button primary" bindtap="saveOperation">
        {{form.baseInitialized ? '保存操作' : '初始化底仓'}}
      </button>
      <button class="button plain" bindtap="clearAll">全部清除</button>
    </view>
  </view>
  <calculator-result-card
    wx:if="{{preview && preview.view && form.baseInitialized}}"
    title="本次预览"
    tag="{{preview.view.actionText}}"
    theme="{{preview.view.theme}}"
    main-items="{{preview.view.mainItems}}"
    detail-items="{{preview.view.detailItems}}"
  />
  <view wx:if="{{summary && form.baseInitialized}}" class="card summary-card compact-summary-card">
    <view class="summary-title">当前持仓</view>
    <view class="summary-main">
      <view class="summary-main-label">{{summary.main.label}}</view>
      <view class="summary-main-value {{summary.main.className}}">{{summary.main.value}}</view>
    </view>
    <view class="summary-grid">
      <block wx:for="{{summary.details}}" wx:key="label">
        <view class="summary-grid-item {{index < 2 ? 'highlight' : ''}}">
          <text>{{item.label}}</text>
          <text class="result-value {{item.className}}">{{item.value}}</text>
        </view>
      </block>
    </view>
  </view>
  <view wx:if="{{operations.length}}" class="embedded-record-list">
    <block wx:for="{{operations}}" wx:key="id">
      <calculator-result-card
        title="{{item.resultTitle}}"
        tag="{{item.resultTagText}}"
        time-text="{{item.resultTimeText}}"
        theme="{{item.resultTheme}}"
        main-items="{{item.mainItems}}"
        detail-items="{{item.detailItems}}"
        removable="{{true}}"
        remove-text="撤销本笔"
        record-id="{{item.id}}"
        bindremove="undoOperation"
      />
    </block>
  </view>
  <view wx:if="{{operations.length && embedded}}" class="result-action-row">
    <button class="button secondary result-share-button" open-type="share">分享给朋友</button>
    <button class="button secondary result-copy-button" bindtap="copyResult">复制结果</button>
  </view>
  <view wx:if="{{operations.length && !embedded}}" class="result-action-bar">
    <button class="action-primary" bindtap="openTradeRecordMiniProgram">算完顺手记录这一笔</button>
    <button class="action-secondary" open-type="share">分享给朋友</button>
    <button class="action-secondary" bindtap="copyResult">复制结果</button>
  </view>
  <button wx:if="{{!embedded}}" class="button plain action-row" bindtap="goBack">返回</button>
  <view class="notice" style="margin-top: 20rpx;">本工具仅用于做T流水和持仓成本测算，不构成任何投资建议。</view>
</view>
