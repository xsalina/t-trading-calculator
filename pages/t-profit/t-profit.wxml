<view class="page">
  <view class="card">
    <view class="section-head">
      <view class="section-title">做T计算器</view>
      <view class="remember-top"><text>记住数据</text><switch color="#00b894" checked="{{rememberData}}" bindchange="onRememberSwitch" /></view>
    </view>
    <view class="switch-row fee-top-row">
      <view class="switch-copy">
        <view>计入手续费</view>
        <view class="hint">{{form.includeFee ? "本次操作会自动估算手续费" : "本次操作将忽略手续费"}}</view>
      </view>
      <switch color="#00b894" checked="{{form.includeFee}}" data-key="includeFee" bindchange="onSwitchChange" />
    </view>
    <view class="field"><text class="label">初始持仓价格</text><view class="step-field"><button class="step-button" data-key="initialPrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.initialPrice}}" data-key="initialPrice" bindinput="onInput" /><button class="step-button" data-key="initialPrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button></view></view>
    <view class="field"><text class="label">初始持仓数量</text><view class="step-field"><button class="step-button" data-key="initialShares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="number" value="{{form.initialShares}}" data-key="initialShares" bindinput="onInput" /><button class="step-button" data-key="initialShares" data-step="100" data-min="0" bindtap="adjustNumber">+</button></view></view>
  </view>

  <view class="card">
    <view class="section-title">添加操作</view>
    <view class="segmented">
      <view class="segment {{form.direction === 'SELL' ? 'active' : ''}}" data-direction="SELL" bindtap="setDirection">卖出</view>
      <view class="segment {{form.direction === 'BUY' ? 'active' : ''}}" data-direction="BUY" bindtap="setDirection">买入</view>
    </view>

    <view wx:if="{{form.direction === 'BUY'}}" class="field">
      <text class="label">成交金额</text>
      <view class="step-field"><button class="step-button" data-key="tradeAmount" data-step="-1000" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.tradeAmount}}" data-key="tradeAmount" bindinput="onInput" placeholder="可选，填金额和买入价格自动算数量" /><button class="step-button" data-key="tradeAmount" data-step="1000" data-min="0" bindtap="adjustNumber">+</button></view>
    </view>

    <view class="field"><text class="label">{{form.direction === "BUY" ? "买入价格" : "卖出价格"}}</text><view class="step-field"><button class="step-button" data-key="tradePrice" data-step="-0.01" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="digit" value="{{form.tradePrice}}" data-key="tradePrice" bindinput="onInput" /><button class="step-button" data-key="tradePrice" data-step="0.01" data-min="0" bindtap="adjustNumber">+</button></view></view>

    <view wx:if="{{form.direction === 'BUY'}}" class="switch-row" style="margin-bottom: 22rpx;">
      <view class="switch-copy"><view>金额换算整手</view><view class="hint">开启按 100 股换算，关闭按 1 股换算。</view></view>
      <switch color="#00b894" checked="{{form.roundLot}}" data-key="roundLot" bindchange="onSwitchChange" />
    </view>

    <view class="field"><text class="label">{{form.direction === "BUY" ? "买入数量" : "卖出数量"}}</text><view class="step-field"><button class="step-button" data-key="tradeShares" data-step="-100" data-min="0" bindtap="adjustNumber">-</button><input class="input" type="number" value="{{form.tradeShares}}" data-key="tradeShares" bindinput="onInput" /><button class="step-button" data-key="tradeShares" data-step="100" data-min="0" bindtap="adjustNumber">+</button></view></view>

    <view class="button-row">
      <button class="button primary" bindtap="saveOperation">保存操作</button>
      <button class="button plain" bindtap="clearAll">全部清除</button>
    </view>
  </view>

  <view wx:if="{{preview}}" class="card">
    <view class="section-title">本次预览</view>
    <block wx:for="{{preview.rows}}" wx:key="label">
      <view class="result-row"><text>{{item.label}}</text><text class="result-value {{item.className}}">{{item.value}}</text></view>
    </block>
  </view>

  <view wx:if="{{summary}}" class="card">
    <view class="section-title">当前持仓</view>
    <block wx:for="{{summary.rows}}" wx:key="label">
      <view class="result-row"><text>{{item.label}}</text><text class="result-value {{item.className}}">{{item.value}}</text></view>
    </block>
  </view>

  <view wx:if="{{operations.length}}" class="card">
    <view class="section-title">操作记录</view>
    <block wx:for="{{operations}}" wx:key="id">
      <view class="trade-record">
        <view class="trade-head">
          <text class="{{item.direction === 'BUY' ? 'negative' : 'positive'}}">{{item.directionText}}</text>
          <text class="muted">{{item.timeText}}</text>
        </view>
        <view class="trade-line"><text>价格</text><text>¥{{item.priceText}}</text></view>
        <view class="trade-line"><text>数量</text><text>{{item.sharesText}} 股</text></view>
        <view class="trade-line"><text>成交金额</text><text>¥{{item.amountText}}</text></view>
        <view class="trade-line"><text>手续费</text><text>¥{{item.feeText}}</text></view>
        <view class="trade-line"><text>本次资金</text><text class="{{item.cashClass}}">{{item.cashText}}</text></view>
        <view class="trade-line"><text>本次收益</text><text class="{{item.profitClass}}">{{item.profitText}}</text></view>
        <view class="trade-line"><text>操作后持仓</text><text>{{item.afterSharesText}}</text></view>
        <view class="trade-line"><text>操作后成本价</text><text>{{item.afterAvgCostText}}</text></view>
        <view class="trade-line"><text>操作后持仓成本</text><text>{{item.afterTotalCostText}}</text></view>
      </view>
    </block>
  </view>

  <button wx:if="{{operations.length}}" class="button secondary" bindtap="openTradeRecordMiniProgram">开始管理我的做T记录</button>

  <button class="button plain action-row" bindtap="goBack">返回</button>

  <navigator class="button secondary" style="margin-top: 16rpx;" url="/pages/fee-settings/fee-settings">手续费设置</navigator>
  <view class="notice" style="margin-top: 20rpx;">本工具仅用于做T流水和持仓成本测算，不构成任何投资建议。</view>
</view>
