<view class="page">
  <view class="card">
    <view class="section-title">默认规则</view>
    <view class="switch-row">
      <view class="switch-copy">
        <view>默认计入交易费用</view>
        <view class="hint">下次新进入计算器时会默认使用这个选择</view>
        <view wx:if="{{!form.useFee}}" class="hint">关闭后，新进入计算器时默认不计入交易费用，已保存的费率配置仍会保留。</view>
      </view>
      <switch color="#3157C8" checked="{{form.useFee}}" data-key="useFee" bindchange="onSwitchChange" />
    </view>
  </view>

  <view class="card">
    <view class="section-title">券商佣金</view>
    <view class="field">
      <view class="switch-row">
        <view>启用券商佣金</view>
        <switch color="#3157C8" checked="{{form.commissionEnabled}}" data-key="commissionEnabled" bindchange="onSwitchChange" />
      </view>
    </view>
    <view class="field">
      <text class="label">佣金费率</text>
      <input class="input" type="digit" value="{{form.commissionRate}}" data-key="commissionRate" bindinput="onInput" />
      <view class="hint">默认 0.00025，表示万 2.5</view>
    </view>
    <view class="field">
      <view class="switch-row">
        <view>启用最低佣金</view>
        <switch color="#3157C8" checked="{{form.commissionMinEnabled}}" data-key="commissionMinEnabled" bindchange="onSwitchChange" />
      </view>
    </view>
    <view class="field">
      <text class="label">最低佣金金额</text>
      <input class="input" type="digit" value="{{form.commissionMinAmount}}" data-key="commissionMinAmount" bindinput="onInput" />
    </view>
  </view>

  <view class="card">
    <view class="section-title">过户费</view>
    <view class="field">
      <view class="switch-row">
        <view>启用过户费</view>
        <switch color="#3157C8" checked="{{form.transferFeeEnabled}}" data-key="transferFeeEnabled" bindchange="onSwitchChange" />
      </view>
    </view>
    <view class="field">
      <text class="label">过户费率</text>
      <input class="input" type="digit" value="{{form.transferFeeRate}}" data-key="transferFeeRate" bindinput="onInput" />
      <view class="hint">默认 0.00001，表示万 0.1</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">印花税</view>
    <view class="field">
      <view class="switch-row">
        <view>启用印花税</view>
        <switch color="#3157C8" checked="{{form.stampDutyEnabled}}" data-key="stampDutyEnabled" bindchange="onSwitchChange" />
      </view>
    </view>
    <view class="field">
      <text class="label">印花税率</text>
      <input class="input" type="digit" value="{{form.stampDutyRate}}" data-key="stampDutyRate" bindinput="onInput" />
      <view class="hint">默认 0.0005，表示万 5</view>
    </view>
    <view class="field">
      <view class="switch-row">
        <view>仅卖出收取</view>
        <switch color="#3157C8" checked="{{form.stampDutyOnlySell}}" data-key="stampDutyOnlySell" bindchange="onSwitchChange" />
      </view>
    </view>
  </view>

  <view class="button-row">
    <button class="button plain" bindtap="reset">恢复默认</button>
    <button class="button primary" bindtap="save">保存</button>
  </view>

  <view class="notice" style="margin-top: 20rpx;">交易费用为估算值，请以券商实际成交费用为准。</view>
</view>
