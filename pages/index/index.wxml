<view class="page">
  <view class="topbar">
    <view class="topbar-content">
      <view class="title">做T交易计算器</view>
      <view class="subtitle">做T、回本、回补、止盈、补仓、卖出和网格区间测算</view>
    </view>
  </view>

  <view class="card">
    <block wx:for="{{calculators}}" wx:key="url">
      <navigator class="list-item" url="{{item.url}}" hover-class="list-item-hover">
        <view class="list-item-left">
          
          <view class="list-icon">
            <text wx:if="{{index === 0}}">📊</text>
            <text wx:elif="{{index === 1}}">🔄</text>
            <text wx:elif="{{index === 2}}">⏳</text>
            <text wx:elif="{{index === 3}}">🎯</text>
            <text wx:elif="{{index === 4}}">➕</text>
            <text wx:elif="{{index === 5}}">💰</text>
            <text wx:elif="{{index === 6}}">🧱</text>
            <text wx:elif="{{index === 7}}">📈</text>
          </view>

          <view>
            <view class="list-title">{{item.name}}</view>
            <view class="list-desc">{{item.desc}}</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </navigator>
    </block>
  </view>

  <view class="miniapp-card" bindtap="openTradeRecordMiniProgram" hover-class="miniapp-card-hover">
    <view class="miniapp-content">
      <view class="miniapp-icon">📱</view>
      <view>
        <view class="miniapp-title">做T记录助手Pro</view>
        <view class="miniapp-desc">开始管理我的做T记录</view>
      </view>
    </view>
    <view class="arrow-white">›</view>
  </view>

  <view class="action-area">
    <navigator class="button secondary" url="/pages/fee-settings/fee-settings" hover-class="btn-hover">手续费设置</navigator>
    
    <button
      class="button secondary contact-button"
      open-type="contact"
      show-message-card="true"
      send-message-title="做T交易计算器"
      send-message-path="/pages/index/index"
      hover-class="btn-hover"
    >在线客服 / 反馈建议</button>
  </view>

  <view class="share-area">
    <button class="button primary share-button" open-type="share" hover-class="share-btn-hover">分享小程序</button>
    <view class="share-copy">感谢您的分享支持，祝您投资顺利！</view>
  </view>

  <view class="notice">本工具仅用于盈亏测算，不构成任何投资建议。</view>
</view>