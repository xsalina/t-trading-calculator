<view class="page">
  <view id="homeCalculator" class="home-calculator-card" wx:if="{{activeCalculator}}">
    <view class="workbench-head">
      <scroll-view scroll-x class="calculator-tab-scroll" show-scrollbar="{{false}}">
        <view class="calculator-tab-list">
          <block wx:for="{{calculators}}" wx:key="type">
            <view
              class="calculator-tab {{item.type === activeCalculatorType ? 'active' : ''}}"
              data-type="{{item.type}}"
              bindtap="switchHomeCalculator"
            >{{item.shortName}}</view>
          </block>
        </view>
      </scroll-view>
    </view>
    <t-profit-calculator wx:if="{{activeCalculatorType === 't-profit'}}" embedded="{{true}}"></t-profit-calculator>
    <break-even-calculator wx:elif="{{activeCalculatorType === 'break-even'}}" embedded="{{true}}"></break-even-calculator>
    <reverse-t-calculator wx:elif="{{activeCalculatorType === 'reverse-t'}}" embedded="{{true}}"></reverse-t-calculator>
    <take-profit-calculator wx:elif="{{activeCalculatorType === 'take-profit'}}" embedded="{{true}}"></take-profit-calculator>
    <average-down-calculator wx:elif="{{activeCalculatorType === 'average-down'}}" embedded="{{true}}"></average-down-calculator>
    <sell-estimate-calculator wx:elif="{{activeCalculatorType === 'sell-estimate'}}" embedded="{{true}}"></sell-estimate-calculator>
    <grid-calculator wx:elif="{{activeCalculatorType === 'grid'}}" embedded="{{true}}"></grid-calculator>
    <price-projection-calculator wx:elif="{{activeCalculatorType === 'price-projection'}}" embedded="{{true}}"></price-projection-calculator>
  </view>

  <view class="card calculator-card compact-calculator-card">
    <view class="independent-head">
      <view>
        <view class="independent-title">需要连续测算？</view>
        <view class="independent-desc">进入独立计算器页面，支持多次计算和完整记录</view>
      </view>
      <view class="independent-toggle" bindtap="toggleAllCalculators">{{showAllCalculators ? '收起' : '查看全部 8 个 >'}}</view>
    </view>
    <block wx:for="{{showAllCalculators ? calculators : featuredCalculators}}" wx:key="type">
      <view class="list-item" data-url="{{item.url}}" bindtap="goCalculatorPage" hover-class="list-item-hover">
        <view class="list-item-left">
          <view class="list-icon">{{item.shortName}}</view>
          <view class="list-copy">
            <view class="list-title">
              <text>{{item.name}}</text>
              <text wx:if="{{item.type === defaultCalculatorType}}" class="default-tag">默认</text>
            </view>
            <view class="list-desc">{{item.desc}}</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </block>
  </view>

  <view class="share-area">
    <button class="button primary share-button" open-type="share" hover-class="share-btn-hover">分享小程序</button>
    <view class="share-copy">感谢您的分享支持，祝您投资顺利！</view>
  </view>
  <view class="action-area">
    <button
      class="button secondary contact-button"
      open-type="contact"
      show-message-card="true"
      send-message-title="做T交易计算器"
      send-message-path="/pages/index/index"
      hover-class="btn-hover"
    >在线客服 / 反馈建议</button>
    <button class="button secondary contact-button" bindtap="openArticle" hover-class="btn-hover">使用说明 / 文章教程</button>
  </view>

  <view class="notice">本工具仅用于盈亏测算，不构成任何投资建议。</view>

  <view wx:if="{{showDefaultPicker}}" class="picker-mask" bindtap="closeDefaultPicker">
    <view class="picker-panel" catchtap="noop">
      <view class="picker-handle"></view>
      <view class="picker-title-row">
        <view class="picker-title">⭐ 选择首页默认计算器</view>
        <view class="picker-close" bindtap="closeDefaultPicker">关闭</view>
      </view>
      <view class="picker-tip">选择后，首页会优先展示这个计算器，方便下次打开直接测算。</view>
      <block wx:for="{{calculators}}" wx:key="type">
        <view class="picker-item" data-type="{{item.type}}" bindtap="chooseDefaultCalculator" hover-class="picker-item-hover">
          <view class="list-item-left picker-left">
            <view class="list-icon">{{item.shortName}}</view>
            <view class="picker-copy">
              <view class="picker-name">{{item.name}}</view>
              <view class="picker-desc">{{item.desc}}</view>
            </view>
          </view>
          <view wx:if="{{item.type === defaultCalculatorType}}" class="picker-current">当前</view>
        </view>
      </block>
    </view>
  </view>
</view>
