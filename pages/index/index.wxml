<view class="page">
  <view wx:if="{{showFavoriteGuide}}" class="favorite-guide" style="{{favoriteGuideStyle}}" catchtap="noop">
    <view class="favorite-guide-body">
      <view class="favorite-guide-copy">
        <view class="favorite-guide-title">添加到我的小程序</view>
        <view class="favorite-guide-desc">点右上角 ···，下次打开更方便</view>
      </view>
      <view class="favorite-guide-close" bindtap="closeFavoriteGuide">×</view>
    </view>
  </view>

  <view id="homeCalculator" class="home-calculator-card" wx:if="{{activeCalculator}}">
    <view class="workbench-head">
      <scroll-view scroll-x class="calculator-tab-scroll" show-scrollbar="{{false}}" scroll-into-view="{{activeTabIntoView}}" scroll-with-animation="{{true}}">
        <view class="calculator-tab-list">
          <block wx:for="{{calculators}}" wx:key="type">
            <view
              id="calculator-tab-{{item.type}}"
              class="calculator-tab {{item.type === activeCalculatorType ? 'active' : ''}}"
              data-type="{{item.type}}"
              bindtap="switchHomeCalculator"
            >{{item.shortName}}</view>
          </block>
        </view>
      </scroll-view>
    </view>
    <view class="calculator-container">
    <t-profit-calculator wx:if="{{activeCalculatorType === 't-profit'}}" embedded="{{true}}" calculator-key="t-profit" entry-query="{{entryQuery}}" is-default-calculator="{{activeCalculatorType === defaultCalculatorType}}" bindsetdefaultcalculator="setCurrentAsDefault" bindresultready="onCalculatorResultReady" bindresultstatechange="onCalculatorResultStateChange"></t-profit-calculator>
    <break-even-calculator wx:elif="{{activeCalculatorType === 'break-even'}}" embedded="{{true}}" calculator-key="break-even" entry-query="{{entryQuery}}" is-default-calculator="{{activeCalculatorType === defaultCalculatorType}}" bindsetdefaultcalculator="setCurrentAsDefault" bindresultready="onCalculatorResultReady" bindresultstatechange="onCalculatorResultStateChange"></break-even-calculator>
    <reverse-t-calculator wx:elif="{{activeCalculatorType === 'reverse-t'}}" embedded="{{true}}" calculator-key="reverse-t" entry-query="{{entryQuery}}" is-default-calculator="{{activeCalculatorType === defaultCalculatorType}}" bindsetdefaultcalculator="setCurrentAsDefault" bindresultready="onCalculatorResultReady" bindresultstatechange="onCalculatorResultStateChange"></reverse-t-calculator>
    <take-profit-calculator wx:elif="{{activeCalculatorType === 'take-profit'}}" embedded="{{true}}" calculator-key="take-profit" entry-query="{{entryQuery}}" is-default-calculator="{{activeCalculatorType === defaultCalculatorType}}" bindsetdefaultcalculator="setCurrentAsDefault" bindresultready="onCalculatorResultReady" bindresultstatechange="onCalculatorResultStateChange"></take-profit-calculator>
    <average-down-calculator wx:elif="{{activeCalculatorType === 'average-down'}}" embedded="{{true}}" calculator-key="average-down" entry-query="{{entryQuery}}" is-default-calculator="{{activeCalculatorType === defaultCalculatorType}}" bindsetdefaultcalculator="setCurrentAsDefault" bindresultready="onCalculatorResultReady" bindresultstatechange="onCalculatorResultStateChange"></average-down-calculator>
    <sell-estimate-calculator wx:elif="{{activeCalculatorType === 'sell-estimate'}}" embedded="{{true}}" calculator-key="sell-estimate" entry-query="{{entryQuery}}" is-default-calculator="{{activeCalculatorType === defaultCalculatorType}}" bindsetdefaultcalculator="setCurrentAsDefault" bindresultready="onCalculatorResultReady" bindresultstatechange="onCalculatorResultStateChange"></sell-estimate-calculator>
    <grid-calculator wx:elif="{{activeCalculatorType === 'grid'}}" embedded="{{true}}" calculator-key="grid" entry-query="{{entryQuery}}" is-default-calculator="{{activeCalculatorType === defaultCalculatorType}}" bindsetdefaultcalculator="setCurrentAsDefault" bindresultready="onCalculatorResultReady" bindresultstatechange="onCalculatorResultStateChange"></grid-calculator>
    <price-projection-calculator wx:elif="{{activeCalculatorType === 'price-projection'}}" embedded="{{true}}" calculator-key="price-projection" entry-query="{{entryQuery}}" is-default-calculator="{{activeCalculatorType === defaultCalculatorType}}" bindsetdefaultcalculator="setCurrentAsDefault" bindresultready="onCalculatorResultReady" bindresultstatechange="onCalculatorResultStateChange"></price-projection-calculator>
  </view>
  </view>

  <view wx:if="{{!activeCalculatorHasResult}}" class="miniapp-card compact-pro-card" bindtap="openTradeRecordMiniProgram" hover-class="miniapp-card-hover">
    <view class="miniapp-content">
      <view class="miniapp-icon">📱</view>
      <view class="miniapp-copy">
        <view class="miniapp-title">做T记录助手Pro</view>
        <view class="miniapp-desc">朋友好评的做T记录神器</view>
      </view>
    </view>
    <view class="arrow-white">去记录 ></view>
  </view>

  <view class="share-area">
    <button class="button secondary fee-settings-button" bindtap="goFeeSettings" hover-class="btn-hover">交易费用设置</button>
    <button class="button primary share-button" open-type="share" hover-class="share-btn-hover">分享小程序</button>
  </view>
  <view class="share-copy">感谢您的分享支持，祝您投资顺利！</view>
  <view class="action-area">
    <button
      class="button secondary contact-button"
      open-type="contact"
      show-message-card="true"
      send-message-title="做T交易计算器"
      send-message-path="/pages/index/index"
      hover-class="btn-hover"
    >在线客服 / 反馈建议</button>
    <button class="button secondary contact-button" bindtap="openArticle" hover-class="btn-hover">使用说明 / 文章教程</button>
  </view>

  <view id="allCalculatorsEntry" class="all-calculators-entry" bindtap="toggleAllCalculators" hover-class="all-calculators-hover">
    <view class="all-calculators-copy">
      <view class="all-calculators-title">全部计算器</view>
      <view class="all-calculators-desc">查看完整计算工具</view>
    </view>
    <view class="all-calculators-action">{{showAllCalculators ? ' 点击折叠' : '查看 8 个 >'}}</view>
  </view>

  <view wx:if="{{showAllCalculators}}" id="bottomCalculatorList" class="card calculator-card compact-calculator-card bottom-calculator-list">
    <block wx:for="{{bottomCalculators}}" wx:key="type">
      <view class="list-item" data-url="{{item.url}}" bindtap="goCalculatorPage" hover-class="list-item-hover">
        <view class="list-item-left">
          <view class="list-icon">{{item.shortName}}</view>
          <view class="list-copy">
            <view class="list-title">
              <text>{{item.name}}</text>
              <text wx:if="{{item.type === defaultCalculatorType}}" class="default-tag">默认</text>
            </view>
            <view class="list-desc">{{item.desc}}</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </block>
  </view>

  <view class="notice">本工具仅用于盈亏测算，不构成任何投资建议。</view>

  <view class="back-to-top {{showBackToTop ? 'visible' : ''}}" bindtap="backToTop">
    <text class="back-to-top-icon">↑</text>
    <text class="back-to-top-text">顶部</text>
  </view>

  <view wx:if="{{showDefaultPicker}}" class="picker-mask" bindtap="closeDefaultPicker">
    <view class="picker-panel" catchtap="noop">
      <view class="picker-handle"></view>
      <view class="picker-title-row">
        <view class="picker-title">⭐ 选择首页默认计算器</view>
        <view class="picker-close" bindtap="closeDefaultPicker">关闭</view>
      </view>
      <view class="picker-tip">选择后，首页会优先展示这个计算器，方便下次打开直接测算。</view>
      <block wx:for="{{calculators}}" wx:key="type">
        <view class="picker-item" data-type="{{item.type}}" bindtap="chooseDefaultCalculator" hover-class="picker-item-hover">
          <view class="list-item-left picker-left">
            <view class="list-icon">{{item.shortName}}</view>
            <view class="picker-copy">
              <view class="picker-name">{{item.name}}</view>
              <view class="picker-desc">{{item.desc}}</view>
            </view>
          </view>
          <view wx:if="{{item.type === defaultCalculatorType}}" class="picker-current">当前</view>
        </view>
      </block>
    </view>
  </view>
</view>
