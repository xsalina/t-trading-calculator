.page {
  min-height: 100vh;
  background-color: #f6f8fa;
  padding: 24rpx;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  background: #ffffff;
  padding: 24rpx 28rpx;
  border-radius: 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  border-left: 8rpx solid #00b894;
}

.topbar-content {
  flex: 1;
  min-width: 0;
}

.article-bulb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #fff7df;
  color: #b7791f;
  font-size: 34rpx;
  box-shadow: 0 6rpx 16rpx rgba(183, 121, 31, 0.16);
}

.topbar .title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.topbar .subtitle {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 8rpx;
  line-height: 1.5;
  max-width: 520rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-subtitle {
  font-size: 23rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  line-height: 1.4;
}

.change-default {
  flex-shrink: 0;
  min-width: 84rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 184, 148, 0.08);
  color: #008f73;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
}

.default-status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.018);
}

.default-status-copy {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 12rpx;
}

.default-status-label {
  flex-shrink: 0;
  padding: 0;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 500;
}

.default-status-name {
  color: #334155;
  font-size: 24rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-section {
  margin-bottom: 28rpx;
}

.home-calculator-card {
  margin-bottom: 24rpx;
}

.fee-summary-card {
  display: block;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.018);
}

.fee-summary-hover {
  background: #f8fafc;
}

.fee-summary-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.fee-summary-title {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 700;
}

.fee-summary-action {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8fff8;
  color: #008f73;
  font-size: 24rpx;
  font-weight: 600;
}

.fee-summary-tip {
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.4;
  margin: -2rpx 0 14rpx;
}

.fee-summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx 18rpx;
}

.fee-summary-item {
  min-width: 0;
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.35;
}

.fee-summary-item text:last-child {
  color: #334155;
  font-weight: 600;
  text-align: right;
}

.quick-scroll {
  margin-top: 18rpx;
  width: 100%;
  white-space: nowrap;
}

.quick-list {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 32rpx;
}

.quick-item {
  min-width: 118rpx;
  height: 76rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  color: #475569;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  box-sizing: border-box;
}

.quick-item-active {
  color: #00b894;
  border-color: rgba(0, 184, 148, 0.38);
  background: #f0fdf9;
}

.quick-default-tag {
  font-size: 18rpx;
  color: #00b894;
  font-weight: 500;
}

.calculator-card {
  padding: 8rpx 0;
}

.list-section-title {
  padding: 28rpx 40rpx 12rpx;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx;
  position: relative;
}

.list-item:not(:last-child)::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 40rpx;
  right: 40rpx;
  height: 1rpx;
  background-color: #f1f5f9;
}

.list-item-hover {
  background-color: #f8fafc;
}

.list-item-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.list-icon {
  width: 76rpx;
  height: 76rpx;
  background-color: #f0fdf9;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #00b894;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.list-copy {
  min-width: 0;
}

.list-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.default-tag {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #e8fff8;
  color: #00b894;
  font-size: 20rpx;
  font-weight: 600;
}

.list-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 6rpx;
  line-height: 1.4;
}

.arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  margin-left: 20rpx;
}

.miniapp-card {
  background: #ffffff;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.018);
  border: 1rpx solid rgba(0, 184, 148, 0.14);
}

.compact-pro-card {
  margin-bottom: 14rpx;
}

.miniapp-card-hover {
  opacity: 0.9;
}

.miniapp-content {
  display: flex;
  align-items: center;
}

.miniapp-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
}

.miniapp-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1e293b;
}

.miniapp-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 2rpx;
}

.arrow-white {
  flex-shrink: 0;
  min-width: 132rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #e8fff8;
  border: 1rpx solid rgba(0, 184, 148, 0.22);
  color: #008f73;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.common-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin: 4rpx 0 18rpx;
}

.action-area {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.action-area .button {
  flex: 1;
  margin: 0 !important;
}

.action-area .contact-button {
  width: 100%;
}

.button {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 72rpx;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.button.secondary {
  background-color: #ffffff;
  color: #475569;
  border: 1rpx solid #e2e8f0;
  padding: 18rpx 0;
  line-height: 1.4;
}

.button.secondary::after,
.button.primary::after {
  border: none;
}

.btn-hover {
  background-color: #f1f5f9 !important;
  color: #1e293b !important;
}

.share-area {
  margin-bottom: 46rpx;
  text-align: center;
}

.button.primary.share-button {
  background-color: #00b894;
  color: #ffffff;
  min-height: 78rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(0, 184, 148, 0.2);
  width: 100% !important;
}

.share-btn-hover {
  background-color: #00a383 !important;
  box-shadow: none !important;
}

.share-copy {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 16rpx;
}

.notice {
  font-size: 22rpx;
  color: #cbd5e1;
  text-align: center;
  line-height: 1.6;
  padding: 0 40rpx;
  margin-top: 32rpx;
}

.picker-mask {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: flex-end;
}

.picker-panel {
  width: 100%;
  max-height: 86vh;
  overflow-y: auto;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 18rpx 32rpx 44rpx;
  box-sizing: border-box;
}

.picker-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  margin: 0 auto 24rpx;
}

.picker-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.picker-close {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.picker-item-hover {
  opacity: 0.72;
}

.picker-copy {
  min-width: 0;
}

.picker-left {
  flex: 1;
  min-width: 0;
}

.picker-left .list-icon {
  width: 68rpx;
  height: 68rpx;
  margin-right: 20rpx;
  font-size: 20rpx;
}

.picker-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.picker-desc {
  font-size: 23rpx;
  color: #64748b;
  line-height: 1.4;
  margin-top: 6rpx;
}

.picker-current {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #00b894;
  background: #e8fff8;
  font-size: 22rpx;
  font-weight: 600;
}

.picker-tip {
  margin: 14rpx 0 8rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: #f0fdf9;
  font-size: 22rpx;
  color: #5f7f77;
  line-height: 1.55;
}
