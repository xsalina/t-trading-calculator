.page {
  min-height: 100vh;
  background-color: #f6f8fa;
  padding: 10rpx 20rpx 24rpx;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-subtitle {
  font-size: 23rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  line-height: 1.4;
}

.favorite-guide {
  position: fixed;
  top: 20rpx;
  right: 90rpx;
  z-index: 90;
  width: 360rpx;
  max-width: 100%;
  pointer-events: auto;
}

.favorite-guide::before {
  content: "";
  position: absolute;
  top: -13rpx;
  right: 42rpx;
  width: 0;
  height: 0;
  border-left: 13rpx solid transparent;
  border-right: 13rpx solid transparent;
  border-bottom: 14rpx solid #ffffff;
  filter: drop-shadow(0 -2rpx 3rpx rgba(15, 23, 42, 0.04));
}

.favorite-guide-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 16rpx 16rpx 16rpx 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(49, 87, 200, 0.18);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
}

.favorite-guide-copy {
  min-width: 0;
}

.favorite-guide-title {
  color: #3157C8;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.25;
}

.favorite-guide-desc {
  margin-top: 4rpx;
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.35;
}

.favorite-guide-close {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 38rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #94a3b8;
  font-size: 30rpx;
  text-align: center;
  box-sizing: border-box;
}

.home-calculator-card {
  margin-bottom: 12rpx;
}

.workbench-head {
  margin-bottom: 4rpx;
}

.calculator-tab-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 2rpx;
}

.calculator-tab-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx; /* 增加一点内边距，让胶囊看起来不拥挤 */
}

.calculator-tab {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 34rpx;
  border-radius: 16rpx; /* 稍微柔和一点的圆角 */
  background: #f1f5f9;  /* 非常浅的灰色，更高级 */
  color: #64748b;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* 平滑过渡 */
}
/* --- 2. 计算区整体容器优化 (在 WXML 中建议给组件包一层) --- */
.calculator-container {
  background: #ffffff;
  padding: 24rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.calculator-tab.active {
  background: #3157C8;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(49, 87, 200, 0.3); /* 增加阴影，使其“浮”起来 */
  transform: scale(1.05); /* 点击激活时微微放大，增加交互感 */
}

.workbench-current {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 4rpx 2rpx 8rpx;
  border-bottom: 1rpx solid #e9eef4;
}

.workbench-copy {
  min-width: 0;
}

.workbench-title {
  color: #1e293b;
  font-size: 27rpx;
  font-weight: 700;
  display: inline;
}

.workbench-default {
  flex-shrink: 0;
  min-width: 110rpx;
  height: 40rpx;
  line-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(49, 87, 200, 0.1);
  color: #2446A8;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.workbench-default.is-default {
  min-width: 76rpx;
  background: #f1f5f9;
  color: #64748b;
}

.calculator-card {
  padding: 0;
}

.compact-calculator-card {
  overflow: hidden;
}

.bottom-calculator-list {
  margin-bottom: 18rpx;
}

.independent-head {
  width:100%;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
  padding: 18rpx 24rpx 8rpx;
}

.independent-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.independent-desc {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.35;
}

.independent-toggle {
  flex-shrink: 0;
  color: #2446A8;
  font-size: 23rpx;
  font-weight: 700;
  padding: 8rpx 0;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 24rpx;
  position: relative;
}

.list-item:not(:last-child)::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 28rpx;
  right: 28rpx;
  height: 1rpx;
  background-color: #f1f5f9;
}

.list-item-hover {
  background-color: #f8fafc;
}

.list-item-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.list-icon {
  width: 58rpx;
  height: 58rpx;
  background-color: #f3f6ff;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #3157C8;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.list-copy {
  min-width: 0;
}

.list-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 27rpx;
  font-weight: 600;
  color: #1e293b;
}

.default-tag {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  color: #3157C8;
  font-size: 20rpx;
  font-weight: 600;
}

.list-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
  line-height: 1.4;
}

.arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  margin-left: 20rpx;
}

.miniapp-card {
  background: #F7F9FF;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  box-shadow: 0 8rpx 24rpx rgba(49, 87, 200, 0.08);
  border: 1rpx solid rgba(49, 87, 200, 0.22);
}

/* --- 3. Pro 工具区域优化 --- */
.compact-pro-card {
  margin: 48rpx 0 48rpx 0; /* 调整了上下间距，使其呼吸感更好 */
  background: #F7F9FF;
  padding: 32rpx 24rpx;    /* 增加卡片内边距 */
  border-radius: 20rpx;
  border: 1rpx solid rgba(49, 87, 200, 0.22);
  box-shadow: 0 8rpx 24rpx rgba(49, 87, 200, 0.08);
}
.miniapp-card-hover {
  opacity: 0.9;
}

.miniapp-content {
  display: flex;
  align-items: center;
}

.miniapp-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
}

.miniapp-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1e293b;
  margin-bottom: 4rpx;
}

.miniapp-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 2rpx;
}

.arrow-white {
  flex-shrink: 0;
  min-width: 132rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #E9EFFF;
  border: 1rpx solid rgba(49, 87, 200, 0.24);
  color: #2448A8;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.miniapp-card-hover .arrow-white {
  background: #DCE6FF;
}

.common-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin: 4rpx 0 18rpx;
}

.action-area {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.action-area .button {
  flex: 1;
  margin: 0 !important;
}

.action-area .contact-button {
  width: 100%;
}

.all-calculators-entry {
  width: 100%;
  margin: -18rpx 0 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #edf2f7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
}

.all-calculators-hover {
  background: #f8fafc;
}

.all-calculators-copy {
  min-width: 0;
}

.all-calculators-title {
  color: #1e293b;
  font-size: 29rpx;
  font-weight: 800;
}

.all-calculators-desc {
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

.all-calculators-action {
  flex-shrink: 0;
  color: #2446A8;
  font-size: 26rpx;
  font-weight: 800;
}

.button {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 72rpx;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.button.secondary {
  background-color: #ffffff;
  color: #475569;
  border: 1rpx solid #e2e8f0;
  padding: 18rpx 0;
  line-height: 1.4;
}

.button.secondary::after,
.button.primary::after {
  border: none;
}

.btn-hover {
  background-color: #f1f5f9 !important;
  color: #1e293b !important;
}

.share-area {
  display: flex;
  gap: 20rpx;
  margin-bottom: 14rpx;
  text-align: center;
}

.share-area .button {
  flex: 1;
  width: 0 !important;
  margin: 0 !important;
}

.fee-settings-button {
  min-height: 78rpx;
  padding: 18rpx 0;
  background: #ffffff;
  color: #1f2937;
  border: 1rpx solid #d8e0ef;
  font-size: 28rpx;
  font-weight: 600;
}

.button.primary.share-button {
  background-color: #EEF3FF;
  color: #2448A8;
  border: 1rpx solid rgba(49, 87, 200, 0.28);
  min-height: 78rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 18rpx rgba(49, 87, 200, 0.07);
}

.share-btn-hover {
  background-color: #DDE7FF !important;
  color: #173B8F !important;
  border-color: rgba(49, 87, 200, 0.35) !important;
  box-shadow: none !important;
}

.share-copy {
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
  margin: 0 0 36rpx;
}

.notice {
  font-size: 22rpx;
  color: #cbd5e1;
  text-align: center;
  line-height: 1.6;
  min-height: 112rpx;
  padding: 40rpx 0;
  margin-top: 32rpx;
  box-sizing: border-box;
}

.back-to-top {
  position: fixed;
  right: 24rpx;
  bottom: calc(38rpx + env(safe-area-inset-bottom));
  z-index: 18;
  min-width: 140rpx;
  height: 78rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #FFFFFF;
  color: #3157C8;
  border: 1rpx solid rgba(49, 87, 200, 0.22);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.12);
  opacity: 0;
  pointer-events: none;
  transform: translateY(16rpx);
  transition: opacity 0.2s ease, transform 0.2s ease;
  box-sizing: border-box;
}

.back-to-top.visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.back-to-top-icon {
  font-size: 26rpx;
  font-weight: 800;
}

.back-to-top-text {
  font-size: 22rpx;
  font-weight: 700;
}

.picker-mask {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: flex-end;
}

.picker-panel {
  width: 100%;
  max-height: 86vh;
  overflow-y: auto;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 18rpx 32rpx 44rpx;
  box-sizing: border-box;
}

.picker-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  margin: 0 auto 24rpx;
}

.picker-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.picker-close {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.picker-item-hover {
  opacity: 0.72;
}

.picker-copy {
  min-width: 0;
}

.picker-left {
  flex: 1;
  min-width: 0;
}

.picker-left .list-icon {
  width: 68rpx;
  height: 68rpx;
  margin-right: 20rpx;
  font-size: 20rpx;
}

.picker-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.picker-desc {
  font-size: 23rpx;
  color: #64748b;
  line-height: 1.4;
  margin-top: 6rpx;
}

.picker-current {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #3157C8;
  background: #eef3ff;
  font-size: 22rpx;
  font-weight: 600;
}

.picker-tip {
  margin: 14rpx 0 8rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: #f3f6ff;
  font-size: 22rpx;
  color: #5f6f9a;
  line-height: 1.55;
}
