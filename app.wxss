page {
  min-height: 100%;
  background: #f6f7fb;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

button,
navigator {
  box-sizing: border-box;
}

button {
  min-width: 0;
}

.page {
  padding: 28rpx;
  box-sizing: border-box;
}

.calculator-shell.standalone {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.calculator-shell.embedded {
  padding: 0;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #16202a;
}

.subtitle {
  margin-top: 8rpx;
  color: #65758b;
  line-height: 1.5;
}

.card {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: flex-start;
  background: #ffffff;
  border: 1rpx solid #e4e8ef;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.section-title {
  width: 100%;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #1f2933;
}

.field {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  margin-bottom: 22rpx;
}

.full-field {
  width: 100%;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #465567;
  font-size: 26rpx;
  text-align: center;
}

.field-tip {
  margin-top: 8rpx;
  color: #8a97a8;
  font-size: 21rpx;
  line-height: 1.35;
}

.input {
  width: 100%;
  height: 64rpx;
  padding: 0 14rpx;
  border: 1rpx solid #d9e0ea;
  border-radius: 8rpx;
  background: #fbfcfe;
  box-sizing: border-box;
  font-size: 28rpx;
}

.step-field {
  display: grid;
  grid-template-columns: 54rpx minmax(0, 1fr) 54rpx;
  align-items: center;
  gap: 8rpx;
}

.step-button {
  width: 54rpx;
  min-width: 54rpx;
  max-width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0;
  margin: 0;
  border-radius: 8rpx;
  background: rgba(0, 184, 148, 0.12);
  color: #008f73;
  font-size: 30rpx;
  font-weight: 700;
}

.step-button::after {
  border: 0;
}

.step-field .input {
  text-align: center;
}

.section-head {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.remember-top {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #465567;
  font-size: 22rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.remember-top switch {
  transform: scale(0.72);
  transform-origin: right center;
}

.switch-row,
.result-row,
.fee-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.fee-top-row {
  margin-bottom: 22rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #eef1f5;
}

.switch-copy {
  flex: 1;
}

.hint {
  margin-top: 8rpx;
  color: #77869a;
  font-size: 24rpx;
  line-height: 1.45;
}

.button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 78rpx;
  line-height: 78rpx;
  padding: 0 20rpx;
  margin: 0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.button::after {
  border: 0;
}

.primary {
  background: #00b894;
  color: #ffffff;
}

.secondary {
  background: rgba(0, 184, 148, 0.12);
  color: #008f73;
}

.share-button {
  margin-top: 16rpx;
}

.contact-button {
  margin-top: 16rpx;
}

.share-area {
  margin-top: 16rpx;
}

.share-area .share-button {
  margin-top: 0;
}

.share-copy {
  margin-top: 12rpx;
  color: #65758b;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
}

.plain {
  background: #ffffff;
  color: #4b5b70;
  border: 1rpx solid #d9e0ea;
}

.button-row {
  display: flex;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.button-row .button {
  flex: 1;
  width: 0;
  min-width: 0;
  max-width: none;
}

.action-row {
  margin-bottom: 16rpx;
}

.result-value {
  font-weight: 700;
  color: #16202a;
}

.positive {
  color: #d64b3c;
}

.negative {
  color: #138a57;
}

.muted {
  color: #77869a;
}

.fee-row,
.result-row {
  min-height: 54rpx;
  border-bottom: 1rpx solid #eef1f5;
}

.fee-row:last-child,
.result-row:last-child {
  border-bottom: 0;
}

.notice {
  width: 100%;
  color: #7a5b12;
  background: #fff7df;
  border: 1rpx solid #f2dfaa;
  border-radius: 8rpx;
  margin-top:40rpx;
  padding: 20rpx;
  line-height: 1.5;
  font-size: 24rpx;
  box-sizing: border-box;
}

.segmented {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 22rpx;
  padding: 8rpx;
  border-radius: 8rpx;
  background: #f2f5f7;
}

.segment {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 8rpx;
  color: #4b5b70;
  font-weight: 600;
}

.segment.active {
  color: #ffffff;
  background: #00b894;
}

.choice-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  width: 100%;
}

.choice-item {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 8rpx;
  border: 1rpx solid #d9e0ea;
  background: #ffffff;
  color: #4b5b70;
  font-size: 26rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.choice-item.active {
  color: #008f73;
  background: rgba(0, 184, 148, 0.12);
  border-color: rgba(0, 184, 148, 0.36);
}

.trade-record {
  width: 100%;
  padding: 18rpx 0;
  border-top: 1rpx solid #eef1f5;
}

.trade-record:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.trade-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.undo-button {
  width: auto;
  min-width: 132rpx;
  height: 46rpx;
  line-height: 46rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #ef4444;
  background: #fff5f5;
  border: 1rpx solid #fee2e2;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
}

.undo-button::after {
  border: 0;
}

.result-head {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16202a;
}

.small-button {
  width: auto;
  min-width: 0;
  max-width: 160rpx;
  height: 48rpx;
  line-height: 48rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
  font-size: 22rpx;
  font-weight: 500;
}

.small-button::after {
  border: 0;
}

.trade-head,
.trade-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.trade-head {
  margin-bottom: 10rpx;
  font-weight: 700;
}

.trade-line {
  min-height: 44rpx;
  color: #465567;
  font-size: 24rpx;
}

.list-item {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 98rpx;
  border-bottom: 1rpx solid #eef1f5;
}

.list-item:last-child {
  border-bottom: 0;
}

.miniapp-card {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(0, 184, 148, 0.24);
  border-radius: 8rpx;
  background: rgba(0, 184, 148, 0.08);
  box-sizing: border-box;
}

.miniapp-title {
  font-weight: 700;
  color: #008f73;
}

.miniapp-desc {
  margin-top: 6rpx;
  color: #5d6c7f;
  font-size: 24rpx;
}

.list-title {
  font-weight: 600;
  color: #1f2933;
}

.list-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #77869a;
}

.arrow {
  color: #9aa7b8;
  font-size: 36rpx;
}

.grid-table {
  width: 100%;
  overflow-x: auto;
}

.grid-head,
.grid-line {
  display: grid;
  grid-template-columns: 90rpx 180rpx 180rpx 190rpx;
  min-width: 640rpx;
  align-items: center;
}

.grid-head {
  color: #65758b;
  font-size: 24rpx;
  min-height: 52rpx;
}

.grid-line {
  min-height: 64rpx;
  border-top: 1rpx solid #eef1f5;
}

.projection-table {
  width: 100%;
  overflow-x: auto;
}

.projection-head,
.projection-line {
  display: grid;
  grid-template-columns: 110rpx 170rpx 220rpx 200rpx 150rpx;
  min-width: 850rpx;
  align-items: center;
}

.projection-head {
  min-height: 52rpx;
  color: #65758b;
  font-size: 24rpx;
}

.projection-line {
  min-height: 64rpx;
  border-top: 1rpx solid #eef1f5;
}
