page {
  --brand-color: #3157C8;
  --page-bg: #F5F7FB;
  --card-bg: #FFFFFF;
  --panel-bg: #F7F8FA;
  --soft-panel-bg: #F5F7FB;
  --border-color: #E6EAF2;
  --text-title: #1F2937;
  --text-main: #24324A;
  --text-secondary: #667085;
  --text-weak: #98A2B3;
  --result-primary: #173B8F;
  --result-up: #E4572E;
  --result-up-bg: #FFF4F1;
  --result-down: #079455;
  --result-down-bg: #F0FDF4;
  --danger-color: #E5483F;
  --danger-bg: #FFF5F5;
  min-height: 100%;
  background: #F5F7FB;
  color: #24324A;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

button,
navigator {
  box-sizing: border-box;
}

button {
  min-width: 0;
}

.page {
  padding: 28rpx;
  box-sizing: border-box;
}

.calculator-shell.standalone {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.calculator-shell.embedded {
  padding: 0;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #16202a;
}

.subtitle {
  margin-top: 8rpx;
  color: #65758b;
  line-height: 1.5;
}

.card {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: flex-start;
  background: #ffffff;
  border: 1rpx solid #e4e8ef;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.section-title {
  width: 100%;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #1f2933;
}

.field {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  margin-bottom: 22rpx;
}

.full-field {
  width: 100%;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #465567;
  font-size: 26rpx;
  text-align: center;
}

.field-tip {
  margin-top: 8rpx;
  color: #8a97a8;
  font-size: 21rpx;
  line-height: 1.35;
}

.input {
  width: 100%;
  height: 64rpx;
  padding: 0 14rpx;
  border: 1rpx solid #d9e0ea;
  border-radius: 8rpx;
  background: #fbfcfe;
  box-sizing: border-box;
  font-size: 28rpx;
}

.step-field {
  display: grid;
  grid-template-columns: 54rpx minmax(0, 1fr) 54rpx;
  align-items: center;
  gap: 8rpx;
}

.step-button {
  width: 54rpx;
  min-width: 54rpx;
  max-width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0;
  margin: 0;
  border-radius: 8rpx;
  background: rgba(49, 87, 200, 0.12);
  color: #2446A8;
  font-size: 30rpx;
  font-weight: 700;
}

.step-button::after {
  border: 0;
}

.step-field .input {
  text-align: center;
}

.section-head {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.remember-top {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #465567;
  font-size: 22rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.remember-top switch {
  transform: scale(0.72);
  transform-origin: right center;
}

.switch-row,
.result-row,
.fee-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.fee-top-row {
  margin-bottom: 22rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #eef1f5;
}

.switch-copy {
  flex: 1;
}

.hint {
  margin-top: 8rpx;
  color: #77869a;
  font-size: 24rpx;
  line-height: 1.45;
}

.button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 78rpx;
  line-height: 78rpx;
  padding: 0 20rpx;
  margin: 0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.button::after {
  border: 0;
}

.primary {
  background: #EEF3FF;
  color: #2448A8;
  border: 1rpx solid rgba(49, 87, 200, 0.22);
  box-shadow: none;
  font-weight: 600;
}

.primary:active {
  background: #DDE7FF;
  border-color: rgba(49, 87, 200, 0.35);
  color: #173B8F;
  transform: scale(0.99);
}

.primary[disabled],
.primary.disabled {
  background: #F2F4F7;
  color: #B0B8C5;
  border-color: #E4E7EC;
  box-shadow: none;
}

.secondary {
  background: rgba(49, 87, 200, 0.12);
  color: #2446A8;
}

.share-button {
  margin-top: 16rpx;
}

.contact-button {
  margin-top: 16rpx;
}

.share-area {
  margin-top: 16rpx;
}

.share-area .share-button {
  margin-top: 0;
}

.share-copy {
  margin-top: 12rpx;
  color: #65758b;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
}

.plain {
  background: #ffffff;
  color: #4b5b70;
  border: 1rpx solid #d9e0ea;
}

.button-row {
  display: flex;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.button-row .button {
  flex: 1;
  width: 0;
  min-width: 0;
  max-width: none;
}

.action-row {
  margin-bottom: 16rpx;
}

.result-value {
  font-weight: 700;
  color: #173B8F;
}

.positive {
  color: #E4572E;
}

.negative {
  color: #079455;
}

.muted {
  color: #98A2B3;
}

.fee-row,
.result-row {
  min-height: 54rpx;
  border-bottom: 1rpx solid #E6EAF2;
}

.fee-row:last-child,
.result-row:last-child {
  border-bottom: 0;
}

.notice {
  width: 100%;
  color: #7a5b12;
  background: #fff7df;
  border: 1rpx solid #f2dfaa;
  border-radius: 8rpx;
  margin-top:40rpx;
  padding: 20rpx;
  line-height: 1.5;
  font-size: 24rpx;
  box-sizing: border-box;
}

.segmented {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 22rpx;
  padding: 8rpx;
  border-radius: 8rpx;
  background: #f2f5f7;
}

.segment {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 8rpx;
  color: #4b5b70;
  font-weight: 600;
}

.segment.active {
  color: #ffffff;
  background: #3157C8;
}

.choice-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  width: 100%;
}

.choice-item {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 8rpx;
  border: 1rpx solid #d9e0ea;
  background: #ffffff;
  color: #4b5b70;
  font-size: 26rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.choice-item.active {
  color: #2446A8;
  background: rgba(49, 87, 200, 0.12);
  border-color: rgba(49, 87, 200, 0.36);
}

.trade-record {
  width: 100%;
  padding: 18rpx 0;
  border-top: 1rpx solid #E6EAF2;
}

.trade-record:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.trade-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.undo-button {
  width: auto;
  min-width: 132rpx;
  height: 46rpx;
  line-height: 46rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #E5483F;
  background: #FFF5F5;
  border: 1rpx solid #FBD6D3;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
}

.undo-button::after {
  border: 0;
}

.result-head {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
}

.small-button {
  width: auto;
  min-width: 0;
  max-width: 160rpx;
  height: 48rpx;
  line-height: 48rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #F7F8FA;
  color: #667085;
  border: 1rpx solid #E6EAF2;
  font-size: 22rpx;
  font-weight: 500;
}

.small-button::after {
  border: 0;
}

.trade-head,
.trade-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.trade-head {
  margin-bottom: 10rpx;
  font-weight: 700;
}

.trade-line {
  min-height: 44rpx;
  color: #465567;
  font-size: 24rpx;
}

.list-item {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 98rpx;
  border-bottom: 1rpx solid #eef1f5;
}

.list-item:last-child {
  border-bottom: 0;
}

.miniapp-card {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(49, 87, 200, 0.24);
  border-radius: 8rpx;
  background: rgba(49, 87, 200, 0.08);
  box-sizing: border-box;
}

.miniapp-title {
  font-weight: 700;
  color: #2446A8;
}

.miniapp-desc {
  margin-top: 6rpx;
  color: #5d6c7f;
  font-size: 24rpx;
}

.list-title {
  font-weight: 600;
  color: #1f2933;
}

.list-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #77869a;
}

.arrow {
  color: #9aa7b8;
  font-size: 36rpx;
}

.grid-table {
  width: 100%;
  overflow-x: auto;
}

.grid-head,
.grid-line {
  display: grid;
  grid-template-columns: 90rpx 180rpx 180rpx 190rpx;
  min-width: 640rpx;
  align-items: center;
}

.grid-head {
  color: #667085;
  font-size: 24rpx;
  min-height: 52rpx;
}

.grid-line {
  min-height: 64rpx;
  border-top: 1rpx solid #E6EAF2;
}

.projection-table {
  width: 100%;
  overflow-x: auto;
}

.projection-head,
.projection-line {
  display: grid;
  grid-template-columns: 110rpx 170rpx 220rpx 200rpx 150rpx;
  min-width: 850rpx;
  align-items: center;
}

.projection-head {
  min-height: 52rpx;
  color: #667085;
  font-size: 24rpx;
}

.projection-line {
  min-height: 64rpx;
  border-top: 1rpx solid #E6EAF2;
}

/* ==========================================================================
   做T计算器 - 结果区域视觉优化（只修改CSS，提升对比度与易读性）
   ========================================================================== */

.result-label,
.target-result-label,
.net-result-label {
  color: #98A2B3 !important;
  font-size: 22rpx !important;
  font-weight: normal !important;
}

.result-value-blue,
.status-value-blue {
  color: #173B8F !important;
  font-weight: 700 !important;
  font-size: 44rpx !important;
}

.result-value-red,
.target-result-value,
.net-result-value,
.table-value-red {
  color: #E4572E !important;
  font-weight: 700 !important;
}

.result-value-green,
.table-value-green {
  color: #079455 !important;
  font-weight: 600 !important;
}

.result-card-box,
.target-box-red {
  background-color: #FFF4F1 !important;
  border: 1rpx solid #FAD8CF !important;
}

.target-box-blue {
  background-color: #F7F8FA !important;
  border: 1rpx solid #E6EAF2 !important;
}

.table-header {
  color: #667085 !important;
  font-size: 24rpx !important;
}

.table-row-value {
  color: #24324A !important;
  font-weight: 500 !important;
}

.back-to-top {
  position: fixed;
  right: 24rpx;
  bottom: calc(38rpx + env(safe-area-inset-bottom));
  z-index: 18;
  min-width: 140rpx;
  height: 78rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #FFFFFF;
  color: #3157C8;
  border: 1rpx solid rgba(49, 87, 200, 0.22);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.12);
  opacity: 0;
  pointer-events: none;
  transform: translateY(16rpx);
  transition: opacity 0.2s ease, transform 0.2s ease;
  box-sizing: border-box;
}

.back-to-top.visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.back-to-top-icon {
  font-size: 26rpx;
  font-weight: 800;
}

.back-to-top-text {
  font-size: 22rpx;
  font-weight: 700;
}
